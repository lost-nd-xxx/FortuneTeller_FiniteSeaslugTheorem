//********************************
// 占いリソース2
//********************************

// 感情選択後の追加語り
// 感情：希望／不安／複雑／無感

// --------------------------------
// 赤の追加語り（生命/身体/宿縁）
// --------------------------------

占い追加語り生命希望
{
	<<'
	生きる力に希望を見たのミャ。
	来週の楽しみがあるとか、
	会いたい人がいるとか、
	食べたいものがあるとか。
	そういう小さな灯りが、
	朝起き上がる理由になっていたりするのミャ。
	大きな目標じゃなくても、
	灯りは灯りミャ。
	'>>
}

占い追加語り生命不安
{
	<<'
	生きる力に不安を覚えるのミャか。
	このまま持つのか、とか、
	支えにしていたものが揺らいでいるとか、
	そういう感覚があるのかミャ。
	不安を抱えたまま立っているのも、
	ひとつの力ではあるのミャ。
	'>>
}

占い追加語り生命複雑
{
	<<'
	生きる力は、簡単に整理できるものじゃないのミャ。
	嬉しいことと辛いことが、同じ根っこから
	生えていたりするのミャ。
	どっちかだけ引き抜くわけにもいかない、
	そういうものなのミャ。
	'>>
}

占い追加語り生命無感
{
	<<'
	生きる力と言われても、ぴんとこないのミャか。
	毎日やっていることが当たり前すぎて、
	それが力だと思えないのかもしれないミャ。
	でも、ここにいること自体が
	すでに何かを使っているのミャ。
	'>>
}

占い追加語り生命逆希望
{
	<<'
	隠れた力に希望を感じたのミャ。
	自分でも気づいていない踏ん張りとか、
	まだ使っていない何かがあるかもしれない、
	そう思えたのは、
	（ユーザ）の底力を信じているからかミャ。
	'>>
}

占い追加語り生命逆不安
{
	<<'
	見えない力のことが不安なのミャか。
	気力が底を打っているのか、
	それともまだ余力があるのか、
	自分のことなのにわからないのは、
	たしかに心もとないのミャ。
	'>>
}

占い追加語り生命逆複雑
{
	<<'
	抑えられた力に複雑な気持ちミャか。
	出したいのに出せないのか、
	出さない方がいいのかわからないのか。
	我慢しているのか、温存しているのか、
	その境目が自分でもあいまいなのかもしれないミャ。
	'>>
}

占い追加語り生命逆無感
{
	<<'
	何も感じないのミャか。
	抑えられた力というのは、
	抑えていることすら忘れるくらい、
	奥にしまい込んでいることもあるのミャ。
	思い出すかどうかは、（ユーザ）次第ミャ。
	'>>
}

占い追加語り身体希望
{
	<<'
	今ここにあるものに希望を見たのミャ。
	体の調子が上向いてきたとか、
	気持ちが少し軽くなったとか、
	そういう手応えがあるのかミャ。
	内側が味方してくれている感じミャ。
	'>>
}

占い追加語り身体不安
{
	<<'
	内側のことだから、
	不安になるのも仕方ないのミャ。
	体がだるいとか、気分が晴れないとか、
	原因がわからないまま抱えていること、
	あるんじゃないかミャ。
	'>>
}

占い追加語り身体複雑
{
	<<'
	身体のことは複雑ミャ。
	頭ではわかっているのに体がついてこないとか、
	気持ちは元気なのにどこか重いとか。
	心と体の足並みが揃わないのは、
	珍しい話じゃないのミャ。
	'>>
}

占い追加語り身体無感
{
	<<'
	身体のことは、調子がいいときほど
	意識しないものミャ。
	肩が凝ってるとか、目が疲れてるとか、
	言われて初めて気づくこともあるのミャ。
	何も感じないのは、
	元気な証拠かもしれないし、
	鈍くなっているだけかもしれないミャ。
	たまには自分の体に聞いてみるといいのミャ。
	'>>
}

占い追加語り身体逆希望
{
	<<'
	まだ気づいていない内側のものに、
	希望を感じたのミャ。
	自分が思っているより回復が早いとか、
	思ったより感情が落ち着いてきているとか、
	そういう兆しを勘で拾っているのかもしれないミャ。
	'>>
}

占い追加語り身体逆不安
{
	<<'
	見えていない内側のこと、
	不安に思うのは当然ミャ。
	疲れが溜まっているのに気づけていないとか、
	感情の蓋がいつ開くかわからないとか。
	でも、見えないことと無いことは違うのミャ。
	'>>
}

占い追加語り身体逆複雑
{
	<<'
	気づいていない内側への複雑な気持ちミャか。
	何かがおかしい気はするのに、
	どこがおかしいのかわからない。
	感覚の方が先に動いていて、
	頭がまだ追いついていないのかもしれないミャ。
	'>>
}

占い追加語り身体逆無感
{
	<<'
	何も感じないのミャか。
	内側のことは、痛みが出るまで
	気づかないことも多いのミャ。
	それが怠慢なんじゃなくて、
	人の体はそういう仕組みになっているのミャ。
	'>>
}

占い追加語り宿縁希望
{
	<<'
	（ユーザ）を囲むものに希望を感じたのミャ。
	職場の空気が少し変わったとか、
	家族との会話が増えたとか、
	最近知り合った人が妙に気が合うとか。
	自分の力じゃどうにもならないはずの
	環境の方が、ちょっとだけ
	味方してくれている感じがするのかミャ。
	'>>
}

占い追加語り宿縁不安
{
	<<'
	外側のことだから、自分では、
	どうにもならないと感じるのかミャ。
	隣の席の人が合わないとか、
	家の周りの環境が変わりそうだとか。
	自分で選べない部分に左右されるのは、
	不安になって当然ミャ。
	水槽の水質は、魚には変えられないのミャ。
	'>>
}

占い追加語り宿縁複雑
{
	<<'
	他者や環境との関係は、もとから複雑なものミャ。
	お世話になった人に苦手意識があるとか、
	居心地の悪い場所なのに離れられないとか。
	恩と重荷が、同じ手から渡されることもあるのミャ。
	すっきりしないのが普通なのミャ。
	'>>
}

占い追加語り宿縁無感
{
	<<'
	周りの環境について、特に何も思わないのミャか。
	毎日通る道を景色として見なくなるみたいに、
	慣れると感じなくなるのミャ。
	それが楽なのか、それとも麻痺しているのかは
	（ユーザ）にしかわからないミャ。
	'>>
}

占い追加語り宿縁逆希望
{
	<<'
	隠れた関係に希望を感じたのミャ。
	知らないうちに、誰かが
	（ユーザ）のことを気にかけていたり、
	たまたま座った席の隣の人が、
	後々大事な人になったり。
	まだ見えていない糸が、（ユーザ）をどこかに
	繋いでいるのかもしれないミャ。
	'>>
}

占い追加語り宿縁逆不安
{
	<<'
	見えない何かが囲んでいると思えば、
	不安にもなるミャ。
	知らない人の噂話に自分の名前が出ていたらとか、
	気づかないところで評価されていたらとか。
	でも、隠れているものは敵、とは限らないのミャ。
	味方が静かにしているだけかもしれないミャ。
	'>>
}

占い追加語り宿縁逆複雑
{
	<<'
	気づいていない関係への複雑な気持ちミャか。
	何かの力が働いている気はするのに、
	正体がわからない。
	うまくいっているのに
	自分の実力じゃない気がするとか、
	なぜか避けられている気がするとか。
	見えない糸に操られている感じは、
	落ち着かないものミャ。
	'>>
}

占い追加語り宿縁逆無感
{
	<<'
	隠れた縁って言われてもミャ。
	見えないものについて、
	感想を持て、という方が難しいのミャ。
	ただ、偶然だと思っていたことが
	実は偶然じゃなかった、
	ということは時々あるのミャ。
	今はわからなくても、後でわかることもあるのミャ。
	'>>
}

// --------------------------------
// 橙の追加語り（活力/情熱/責任）
// --------------------------------

占い追加語り活力希望
{
	<<'
	内側の力に希望を見たのミャ。
	朝、布団から出られたとか、
	何かをやってみようと思えたとか、
	そういう湧き上がるものがあるなら、
	それは（ユーザ）自身のものミャ。
	'>>
}

占い追加語り活力不安
{
	<<'
	力があるのに不安を感じる。
	それは、その力をどう使えばいいか
	迷っているのかミャ。
	やりたいことはあるのに、動き出すのが怖い、とか。
	空回りしそうで踏み出せない、とか。
	そういうことかもしれないミャ。
	'>>
}

占い追加語り活力複雑
{
	<<'
	活力への気持ちが複雑ミャか。
	頑張りたいのに体が重いとか、
	休みたいのに焦りが止まらないとか、
	アクセルとブレーキを同時に踏んでいる感じ。
	やる気はあるのに動けない夜とか、
	動いているのに充実感がない日とか。
	エンジンの調子が悪いだけで、
	壊れているわけじゃないのミャ。
	'>>
}

占い追加語り活力無感
{
	<<'
	何も感じないのも、
	力の使い方のひとつかもしれないミャ。
	毎日同じことを繰り返していると、
	それに力を使っている実感が湧かないのミャ。
	でも、静かにしているのも力なのミャ。
	'>>
}

占い追加語り活力逆希望
{
	<<'
	眠っている力に希望を感じたのミャ。
	今はぐったりしていても、
	きっかけひとつで跳ね起きることもあるのミャ。
	まだ目覚めていないだけで、
	そこにあるのかもしれないミャ。
	'>>
}

占い追加語り活力逆不安
{
	<<'
	沈んでいる力のことが気になるのかミャ。
	やらなきゃいけないのに体が動かないとか、
	やる気を出したいのに、
	スイッチが見つからないとか。
	底の方に沈んだものが浮かび上がるかどうか、
	それは誰にもわからないのミャ。
	でも、気にしている時点で
	完全には沈んでいないのかミャ。
	'>>
}

占い追加語り活力逆複雑
{
	<<'
	まだ見えない力への複雑な気持ちミャか。
	本当は元気なのに出し方がわからないのか、
	本当に枯れているのか、
	自分でも判別がつかないのミャ。
	電池が切れたのか、接触不良なのかわからないまま
	リモコンを振っているような感じかミャ。
	'>>
}

占い追加語り活力逆無感
{
	<<'
	隠れたエネルギーとか言われても、
	ぴんとこないのミャか。
	まあ、地下水脈みたいなものミャ。
	地面の上からは見えないけど、
	井戸を掘れば出てくるかもしれないし、
	掘らなければそのまま流れていくだけミャ。
	今は掘る時じゃないのかもしれないミャ。
	'>>
}

占い追加語り情熱希望
{
	<<'
	（ユーザ）だけの熱に希望を見たのミャ。
	誰かのために頑張りたいとか、
	これだけは譲れないと思うものがあるとか。
	その熱があるうちは、
	（ユーザ）は動けるのかもしれないミャ。
	'>>
}

占い追加語り情熱不安
{
	<<'
	熱があるからこそ、不安にもなるミャ。
	このまま突っ走って大丈夫なのかとか、
	周りから浮いてないかとか。
	好きなことに夢中になりすぎて
	他のことが疎かになっているんじゃないか、
	って心配するのは、
	ちゃんと熱を持っている証拠ミャ。
	冷めた人は冷めることを怖がらないのミャ。
	'>>
}

占い追加語り情熱複雑
{
	<<'
	情熱は厄介なものミャ。
	好きなのに近づけないとか、
	夢中になりたいのに冷めた自分がいるとか。
	向けたいのに向けられない、
	そういうこともあるのミャ。
	'>>
}

占い追加語り情熱無感
{
	<<'
	熱について何も思わないのミャか。
	別に燃えるものがないとか、
	そこまで夢中になれるものが見当たらないとか。
	それは冷たいんじゃなくて、まだ火をつけるものに
	出会っていないだけかもミャ。
	出会わないまま終わることもあるけどミャ。
	'>>
}

占い追加語り情熱逆希望
{
	<<'
	押し殺された熱に希望を感じたのミャ。
	諦めたはずの夢を思い出したり、
	もう関係ないはずの人の名前で胸が騒いだり。
	忘れたつもりでも、ふとした瞬間に
	顔を出すものがあるなら、
	それは消えていないということミャ。
	火種が残っているうちは、
	まだ燃やし直せるのミャ。
	'>>
}

占い追加語り情熱逆不安
{
	<<'
	燻っている熱への不安ミャか。
	昔あんなに好きだったものが
	今は全然響かなくなっていたり、
	逆に、忘れたはずのものに
	ふと心を持っていかれたり。
	押し込めた熱が勝手に燃え出すのも、
	このまま灰になるのも、
	どっちも怖いのかミャ。
	'>>
}

占い追加語り情熱逆複雑
{
	<<'
	隠れた熱への複雑な気持ちミャか。
	認めてしまったら走り出さなきゃいけない、
	でも認めなかったら、ずっとこのままミャ。
	諦めたはずの夢がまだ燻っているとか、
	とっくに終わった関係に、まだ熱が残っているとか。
	どうしたいのか、自分でもわからないのかミャ。
	'>>
}

占い追加語り情熱逆無感
{
	<<'
	隠れた熱って言われてもミャ。
	自覚がないものは仕方ないのミャ。
	ただ、ふとした時に妙に気になるニュースとか、
	なぜか目が離せない動画とか、
	そういうのに火種が潜んでいたりするのミャ。
	'>>
}

占い追加語り責任希望
{
	<<'
	背負っているものに希望を見たのミャ。
	頼りにされているとか、
	自分がいないと回らないものがあるとか。
	その役割が（ユーザ）に
	居場所を与えているのかもしれないミャ。
	'>>
}

占い追加語り責任不安
{
	<<'
	背負っているものが重ければ、
	不安にもなるミャ。
	期待に応えられるのか、
	失敗したらどうなるのか。
	そういうことが頭を回るのは、
	真面目に向き合っている証拠なのかミャ。
	'>>
}

占い追加語り責任複雑
{
	<<'
	役割や立場への複雑な気持ちミャか。
	頼りにされるのは悪くないけど、
	断れなくなっているとか。
	自分で引き受けたはずなのに、
	押し付けられた気がしてきたとか。
	選んだものも選ばなかったものも、
	背負ってしまえば同じ重さミャ。
	'>>
}

占い追加語り責任無感
{
	<<'
	責任って言われても、ぴんとこないのミャか。
	毎日やっていることが当たり前すぎて、
	それが責任だとは思えないとか。
	あるいは、もう十分背負った後で、
	今さら何も感じなくなっているのかミャ。
	麻痺も慣れも、背負い続けた結果ではあるのミャ。
	'>>
}

占い追加語り責任逆希望
{
	<<'
	見えない役割に希望を感じたのミャ。
	頼まれたわけでもないのに、
	誰かの支えになっていたり、
	いるだけで場が落ち着いたり。
	気づいていないところで、
	（ユーザ）は何かを担っているのかミャ。
	'>>
}

占い追加語り責任逆不安
{
	<<'
	見えない責任への不安ミャか。
	知らないうちに、誰かの期待を
	背負わされているような感覚。
	断った覚えのない仕事が、
	いつの間にか自分の担当になっていたり、
	何も言っていないのに、頼りにされていたり。
	見えない荷物は、下ろし方もわからないミャ。
	'>>
}

占い追加語り責任逆複雑
{
	<<'
	隠れた役割への複雑な気持ちミャか。
	自分でもよくわからないものを
	背負っている感覚。
	長男・長女だからとか、先輩だからとか、
	言葉にされていない期待が
	空気みたいに張り付いているのかミャ。
	引き受けた覚えはないのに、
	放り出すわけにもいかないミャ。
	'>>
}

占い追加語り責任逆無感
{
	<<'
	見えない役割とか言われてもミャ。
	背負っている自覚がなければ、
	重いも軽いもないのミャ。
	ただ、周りの人が（ユーザ）をどう見ているかは、
	自分ではわからないものミャ。
	知らない方が楽なことも、あるのかもしれないミャ。
	'>>
}

// --------------------------------
// 黄の追加語り（財産/不変/均衡）
// --------------------------------

占い追加語り財産希望
{
	<<'
	積み重ねてきたものに希望を見たのミャ。
	身につけた経験とか、長い付き合いの人とか、
	苦労して覚えたこととか。
	（ユーザ）が得てきたものは、
	ちゃんとそこにあるのミャ。
	'>>
}

占い追加語り財産不安
{
	<<'
	持っているものを失う不安ミャか。
	貯金が減っていくのが怖いとか、
	信頼関係が壊れるかもしれないとか、
	時間をかけて築いたものほど
	失うのが怖いのミャ。
	でも、守ろうとしすぎて
	がちがちに固まるのも苦しいのミャ。
	大事なものは、握りしめなくても
	案外そばにいてくれるものミャ。
	'>>
}

占い追加語り財産複雑
{
	<<'
	積み重ねは、全部が全部、
	良いものとは限らないのミャ。
	役に立っているけど重荷にもなっている技能とか、
	離れられない場所とか。
	複雑で当然なのミャ。
	'>>
}

占い追加語り財産無感
{
	<<'
	積み重ねって言われても、思い当たらないのミャか。
	毎日使っている言葉も、歩き慣れた道も、
	全部（ユーザ）が積み上げてきたものミャ。
	あまりに当たり前すぎて、
	持っていることを忘れている。
	そういうことかミャ。
	'>>
}

占い追加語り財産逆希望
{
	<<'
	見えない蓄積に希望を感じたのミャ。
	自分では大したことないと思っている経験が、
	実は誰かの役に立つものだったり。
	苦労した時期に身についた我慢強さとか、
	失敗から学んだ嗅覚とか。
	（ユーザ）が気づいていないだけで、
	結構な財産を持っているのかもしれないミャ。
	'>>
}

占い追加語り財産逆不安
{
	<<'
	知らないうちに何かを持っている、
	それが不安なのかミャ。
	自分の中にある財産が、
	どれくらいなのかわからない。
	実はもう使い果たしているのか、
	まだ余裕があるのか。
	貯金の残高を確認するのが怖い、
	あの感じに似ているのかミャ。
	'>>
}

占い追加語り財産逆複雑
{
	<<'
	気づいていない持ち物への複雑な気持ちミャか。
	自分の実力なのか、たまたま環境に恵まれたのか。
	親から受け継いだものを
	自分の手柄だとは思えないとか。
	逆に、自力で得たものなのに、
	認めてもらえていない気がするとか。
	自分の財産の正体がわからないのは、
	もどかしいのミャ。
	'>>
}

占い追加語り財産逆無感
{
	<<'
	見えない蓄積とか言われてもミャ。
	自分が何を持っているかなんて、
	普段は考えないものミャ。
	空気を吸っていることに感謝しないのと同じミャ。
	ただ、なくなった時に初めて、あったんだな、
	と気づくことは、あるかもしれないミャ。
	'>>
}

占い追加語り不変希望
{
	<<'
	変わらないことに希望を見たのミャ。
	ずっとある日課とか、変わらない味の店とか、
	何年経っても同じでいてくれる相手とか。
	動かないものが支えになっている、
	そういうこともあるのミャ。
	'>>
}

占い追加語り不変不安
{
	<<'
	変わらないことへの不安、
	それはこのままでいいのか、という
	問いかけなのかミャ。
	周りが動いているのに自分だけ止まっている、
	そういう焦りがあるのかもしれないミャ。
	'>>
}

占い追加語り不変複雑
{
	<<'
	変わらないことへの複雑な気持ちミャか。
	安心するのに息苦しい。
	毎日同じ時間に同じことをするのが
	支えになっているのに、
	ふとこのまま一生これなのか、と思うと
	怖くなるとか。
	安定と停滞は、同じものの裏表なのかミャ。
	'>>
}

占い追加語り不変無感
{
	<<'
	変わらないものについて、何も思わないのミャか。
	水が水であることに、いちいち驚かないように、
	馴染みすぎると感じなくなるのミャ。
	でも、それがなくなった日に、
	初めて気づくこともあるのミャ。
	今は感じなくてもいいのミャ。
	'>>
}

占い追加語り不変逆希望
{
	<<'
	隠れた停滞に希望を感じたのミャ。
	動いていないように見えて、
	実は根を張っている時期なのかミャ。
	冬の木みたいに、地上は枯れて見えるのに、
	地面の下では春の準備をしている。
	（ユーザ）の止まっている時間にも、
	そういう意味があるのかミャ。
	'>>
}

占い追加語り不変逆不安
{
	<<'
	知らないうちに止まっているかもしれない、
	その不安ミャか。
	毎日忙しくしているのに、
	振り返ると何も変わっていない気がするとか。
	同じところを回り続ける、
	ハムスターの車輪みたいな感覚。
	動いているのか止まっているのか、
	それがわからないのが一番怖いのかミャ。
	'>>
}

占い追加語り不変逆複雑
{
	<<'
	気づかない停滞への複雑な気持ちミャか。
	動いているつもりなのに、景色が変わらない。
	頑張っているはずなのに、成果が見えないとか、
	成長している実感がないとか。
	それとも本当は動きたくなくて、
	止まっていることに
	ほっとしている自分がいるのかミャ。
	'>>
}

占い追加語り不変逆無感
{
	<<'
	隠れた停滞とか言われてもミャ。
	気づいていないものは感じようがないのミャ。
	ただ、最近ずっと同じ服ばかり着ているとか、
	休日の過ごし方がワンパターンだとか、
	そういう小さなところに
	兆しが隠れていたりすることもあるのミャ。
	今は気にしなくてもいいけれど、
	頭の隅に置いておくといいミャ。
	'>>
}

占い追加語り均衡希望
{
	<<'
	釣り合いに希望を見たのミャ。
	仕事と休みの配分とか、
	人付き合いとひとりの時間とか。
	バランスが取れているということは、
	何かがうまく回っているのかミャ。
	'>>
}

占い追加語り均衡不安
{
	<<'
	バランスが崩れるかもしれない、
	そういう不安ミャか。
	仕事を増やしたら家のことが回らないとか、
	誰かに優しくしたら、別の誰かが拗ねるとか。
	今の均衡を保つのは綱渡りみたいなもので、
	一歩間違えたら全部崩れそうな
	危うさがあるのかミャ。
	'>>
}

占い追加語り均衡複雑
{
	<<'
	釣り合いへの複雑な気持ちミャか。
	バランスが取れているように見えて、
	実はどこかで無理をしている。
	自分が我慢することで場が丸く収まっているとか、
	本音を言わないことで関係が保たれているとか。
	その均衡は、（ユーザ）の犠牲の上に
	成り立っているのかミャ。
	'>>
}

占い追加語り均衡無感
{
	<<'
	バランスとか言われても、
	特に思うことはないのミャか。
	天秤が傾いていなければ、
	天秤のことは忘れるものミャ。
	うまくいっている時ほど当たり前に感じて、
	ありがたみがわからないのは
	仕方のないことミャ。
	'>>
}

占い追加語り均衡逆希望
{
	<<'
	見えないバランスに希望を感じたのミャ。
	自分では何もしていないつもりなのに、
	なぜか物事がうまく回っている。
	たまたま周りの人と役割が分かれていたり、
	無意識に良い距離感を保てていたりするのかミャ。
	（ユーザ）の勘が、
	うまく天秤を操っているのかもしれないミャ。
	'>>
}

占い追加語り均衡逆不安
{
	<<'
	見えない力で釣り合っている、
	それが崩れたらどうなるのか。
	誰かが抜けたら回らなくなる職場とか、
	ひとつ予定がずれたら、
	全部が連鎖的に崩れるスケジュールとか。
	見えない均衡ほど、崩れた時の衝撃が
	読めないから怖いのかミャ。
	'>>
}

占い追加語り均衡逆複雑
{
	<<'
	隠れたバランスへの複雑な気持ちミャか。
	自分でも知らないうちに、何かを天秤にかけている。
	ある人との関係を優先したら、
	別の関係が薄れていたとか。
	仕事に集中したら、
	体のことを後回しにしていたとか。
	無意識の選択が、何かを犠牲にしているのかミャ。
	'>>
}

占い追加語り均衡逆無感
{
	<<'
	見えないバランスって言われてもミャ。
	裏で何が釣り合っているかなんて、
	普段は考えないのが普通ミャ。
	たとえば家事を誰がやっているかとか、
	職場で誰が調整役を引き受けているかとか、
	うまくいっているときほど見えないのミャ。
	今は気にしなくていいけれど、
	ふと引っかかったら思い出すといいミャ。
	'>>
}

// --------------------------------
// 緑の追加語り（変化/流転/推進）
// --------------------------------

占い追加語り変化希望
{
	<<'
	移ろいに希望を見たのミャ。
	髪型を変えてみようかなとか、
	新しい趣味を始めてみようかなとか、
	今までと違うことに手を伸ばしたくなっている。
	変わることを楽しみにできるのは、
	今の自分をちゃんと踏み台にできている
	ってことでもあるのミャ。
	いい風が吹いているうちに、動くといいミャ。
	'>>
}

占い追加語り変化不安
{
	<<'
	変わることへの不安ミャか。
	たとえば住み慣れた部屋を出るとか、
	ずっと続けてきたことをやめるとか。
	慣れたやり方を手放すのが怖いのは、
	それだけ今あるものを
	大事にしてきたからでもあるのミャ。
	全部一度に変えなくてもいいのミャ。
	少しずつでも、変化は変化ミャ。
	'>>
}

占い追加語り変化複雑
{
	<<'
	変化への気持ちが複雑ミャか。
	たとえば転職したいけど今の同僚は好きだとか、
	引っ越したいけど近所の店に愛着があるとか。
	変わりたい気持ちと、
	変わりたくない気持ちが両方あって、
	どっちも本当なのが厄介なのミャ。
	白黒つけなくていいのミャ。
	揺れながら進むのも、立派な歩き方ミャ。
	'>>
}

占い追加語り変化無感
{
	<<'
	変化って言われてもぴんとこないミャか。
	渦中にいると流れの速さがわからないように、
	変わっている最中ほど気づきにくいのミャ。
	去年の写真を見て、あれ、と思うこととか、
	昔の日記を読んで驚くこととか。
	振り返ったときに初めてわかる変化も
	あるのミャ。今はそれでいいのミャ。
	'>>
}

占い追加語り変化逆希望
{
	<<'
	見えない変化に希望を感じたのミャ。
	最近、なんとなく選ぶものが変わったとか、
	前は素通りしていた棚で足が止まるとか、
	自分でも気づいていない変化が
	もう始まっているのかもしれないミャ。
	芽が土の中で伸びているようなもので、
	表に出てきたときには
	もうしっかり根を張っているのミャ。
	'>>
}

占い追加語り変化逆不安
{
	<<'
	知らないうちに変わっているかもしれない、
	その不安はわかるミャ。
	友達の態度がなんか違う気がするとか、
	自分の体調がじわじわおかしいとか、
	はっきりしないのに落ち着かない感じ。
	気づいたときには手遅れかもって怖いミャよね。
	でも、こうして引っかかっている時点で、
	（ユーザ）はもう気づき始めているのミャ。
	'>>
}

占い追加語り変化逆複雑
{
	<<'
	見えない移ろいへの複雑な気持ちミャか。
	もう変わり始めているのに、
	まだ変わっていないふりをしている、
	そういうことに心当たりはないかミャ？
	好きだった番組を観なくなったとか、
	前ほどあの人の連絡を待たなくなったとか。
	認めたくない変化ほど、
	静かに進んでいたりするのミャ。
	'>>
}

占い追加語り変化逆無感
{
	<<'
	見えない変化とか言われてもミャ。
	見えないものを感じろって言われても、
	それは無理な話ミャ。
	ただ、半年後に今の自分を振り返ったとき、
	あのときもう変わってたんだなって
	思うことはあるかもしれないミャ。
	今わからなくても、
	それは鈍いんじゃなくて、まだ途中なだけミャ。
	'>>
}

占い追加語り流転希望
{
	<<'
	巡りに希望を見たのミャ。
	クラス替えとか、部署異動とか、
	顔ぶれが変わることを
	新しい出会いだと思えるのは強いのミャ。
	去っていく人がいるからこそ、
	来る人のための場所ができる。
	（ユーザ）はその回転を、
	ちゃんと受け止められているのミャ。
	'>>
}

占い追加語り流転不安
{
	<<'
	留まれないことへの不安ミャか。
	仲の良かったグループがばらけていくとか、
	慣れた先輩が異動でいなくなるとか、
	せっかく築いた関係が崩れていくのは
	たしかに心もとないのミャ。
	でも、流されるのと泳ぐのは違うのミャ。
	波の中でも自分の向きだけは
	決められるのミャ。
	'>>
}

占い追加語り流転複雑
{
	<<'
	巡りへの気持ちが複雑ミャか。
	卒業は寂しいけど、ずっと同じ教室も息苦しい。
	人が入れ替わるのは自由でもあり、
	握っていたものが戻ってこない不自由でもある。
	新しい顔ぶれに期待しつつ、
	前の関係を懐かしむ。
	どっちの気持ちも嘘じゃないのミャ。
	'>>
}

占い追加語り流転無感
{
	<<'
	巡りって言われてもミャか。
	人の出入りとか、立場の交代とか、
	あんまり身に覚えがないのかもしれないミャ。
	でも、たとえば行きつけの店が閉まったとか、
	いつもの道に新しい建物が建ったとか、
	そういうのも巡りの一部ミャ。
	大きく感じなくても、
	世界はちゃんと回っているのミャ。
	'>>
}

占い追加語り流転逆希望
{
	<<'
	隠れた巡りに希望を感じたのミャ。
	今は変わらないように見えても、
	裏では人の配置や順番が
	静かに入れ替わり始めているのかもしれないミャ。
	あの人最近元気そうだなとか、
	新しい人が入ってきたなとか、
	小さな兆しに気づいているなら、
	それはもう巡りの始まりミャ。
	'>>
}

占い追加語り流転逆不安
{
	<<'
	知らないうちに何かが巡っている、
	それが不安なのかミャ。
	自分の知らないところで話が進んでいたり、
	いつの間にか担当が変わっていたり、
	根回しが終わった後に聞かされたり。
	蚊帳の外に置かれる感じは
	たしかに落ち着かないのミャ。
	でも、気づいた時点で
	もう蚊帳の外じゃないのミャ。
	'>>
}

占い追加語り流転逆複雑
{
	<<'
	隠れた巡りへの複雑な気持ちミャか。
	何かが変わりそうな空気は感じるのに、
	何が変わるのかがわからない。
	職場の雰囲気がなんとなく違うとか、
	あの人たち最近よく話してるなとか。
	確証はないのに落ち着かない、
	その据わりの悪さが
	一番もやもやするのかもしれないミャ。
	'>>
}

占い追加語り流転逆無感
{
	<<'
	隠れた巡りとか言われてもミャ。
	見えないものに反応しろって方が
	無茶な話ミャ。
	ただ、たとえば最近会わなくなった人とか、
	いつの間にか変わっていた連絡先とか、
	後から『あれが入れ替わりだったのか』と
	思うことはあるかもしれないミャ。
	今はまだ、その途中なだけミャ。
	'>>
}

占い追加語り推進希望
{
	<<'
	前に進む力に希望を見たのミャ。
	資格の勉強を始めたとか、
	企画書をようやく書き上げたとか、
	やろうと決めたことが実際に動き出している。
	止まらずに進めているなら、それは力なのミャ。
	勢いがあるうちに、
	もう一歩踏み出しておくといいミャ。
	'>>
}

占い追加語り推進不安
{
	<<'
	進むことへの不安ミャか。
	このまま突き進んで大丈夫なのかとか、
	途中でやめたら今までの努力が無駄になるとか、
	進んだ先に何もなかったらどうしようとか。
	引き返せない道を歩いている気分は
	たしかに怖いのミャ。
	でも、不安を感じながらも止まっていないなら、
	それはもう立派に進んでいるのミャ。
	'>>
}

占い追加語り推進複雑
{
	<<'
	推進への気持ちが複雑ミャか。
	やりたいことはあるのに腰が上がらないとか、
	逆に望んでもいないのに
	周りに押し出されているとか。
	締切が迫ってるのに手が動かない夜とか、
	頼まれごとで自分の時間がなくなる日とか。
	自分の意志と足の向きが
	噛み合わないのは、しんどいのミャ。
	'>>
}

占い追加語り推進無感
{
	<<'
	進む力って言われてもミャか。
	特に何かに向かっている感じがしないのかもしれないミャ。
	でも、毎日ごはんを食べて、
	朝起きて、やることをやっている。
	それだって立派に前に進んでいるのミャ。
	大きな目標がなくても、
	日々を回しているだけで
	ちゃんと動いているのミャ。
	'>>
}

占い追加語り推進逆希望
{
	<<'
	見えない動きに希望を感じたのミャ。
	自分では何もしていないつもりでも、
	毎日の通勤とか、繰り返す家事とか、
	地味な積み重ねが
	いつの間にか道を作っていることがあるのミャ。
	振り返ったら思ったより遠くに来ていた、
	そういう種類の前進かもしれないミャ。
	'>>
}

占い追加語り推進逆不安
{
	<<'
	知らないうちに何かが進んでいる、
	それが不安なのかミャ。
	気づいたら話がまとまっていたとか、
	自分の知らないところで予定が決まっていたとか、
	舵を握れていない感覚。
	ベルトコンベアに乗せられているみたいで、
	降りたいのに降り方がわからない。
	まず、今どこにいるか確かめるところから
	始めてみるといいのミャ。
	'>>
}

占い追加語り推進逆複雑
{
	<<'
	見えない動きへの複雑な気持ちミャか。
	何かが進んでいる気はするのに、
	それが良い方向なのかわからない。
	仕事が勝手に増えていくのか、
	チャンスが近づいているのか、
	判断がつかないまま日が過ぎていく。
	地図のない道を歩いている感覚は
	不安でもあり、少しだけわくわくもするのミャ。
	'>>
}

占い追加語り推進逆無感
{
	<<'
	見えない動きとか言われてもミャ。
	自分で動かしていないものの勢いなんて、
	わかるわけがないのミャ。
	ただ、たとえば去年書いた履歴書が
	まだどこかで回っていたりとか、
	昔の知り合いが（ユーザ）の名前を出していたりとか、
	知らないところで何かが転がっている、
	ということはあるかもしれないミャ。
	'>>
}

// --------------------------------
// 青の追加語り（意志/幻想/混沌）
// --------------------------------

占い追加語り意志希望
{
	<<'
	望みに希望を見たのミャ。
	こうしたい、こうなりたい、
	そういう方角を持っているのは強いことミャ。
	あの仕事に就きたいとか、
	この人ともっと仲良くなりたいとか、
	具体的でも漠然とでも、
	向かう先があるなら迷っても戻れるのミャ。
	その望みを、大事にするといいミャ。
	'>>
}

占い追加語り意志不安
{
	<<'
	望みがあるからこそ、不安になるのミャ。
	受験に落ちたらどうしようとか、
	告白して断られたらとか、
	叶わなかったときの自分を
	想像してしまうのかミャ。
	でも、望みがなければ不安にすらならないのミャ。
	怖いということは、
	それだけ本気だということミャ。
	'>>
}

占い追加語り意志複雑
{
	<<'
	望みへの複雑な気持ちミャか。
	あっちにもこっちにも行きたくて、
	どれかを選べば残りを捨てることになる。
	安定した仕事と本当にやりたいこととか、
	誰かの期待に応えることと
	自分の気持ちに正直でいることとか。
	望みが複数あるのは贅沢じゃなくて、
	引き裂かれることなのかミャ。
	'>>
}

占い追加語り意志無感
{
	<<'
	望みって言われても、特にないのミャか。
	何がしたいかわからないまま
	日々が過ぎていくのは、
	珍しいことじゃないのミャ。
	コンビニで何を買うかすら、
	決められない日もあるミャ。
	方角は、歩いているうちに
	見つかることもあるのミャ。
	'>>
}

占い追加語り意志逆希望
{
	<<'
	見えない望みに希望を感じたのミャ。
	自分では何も決めていないつもりなのに、
	気づいたらある方向に歩いていた、
	ということはないかミャ。
	無意識に手に取る本とか、
	つい目で追ってしまう求人情報とか。
	（ユーザ）の中で、まだ言葉にならない望みが
	芽を出しかけているのかミャ。
	'>>
}

占い追加語り意志逆不安
{
	<<'
	本当に向かいたい方向がわからない、
	その不安ミャか。
	みんな将来の夢とか目標とか
	持っているように見えるのに、
	自分にはそれがない。
	あるいは、あったはずなのに
	いつの間にか見失った。
	羅針盤のない船に乗っている感覚は、
	心もとないものミャ。
	'>>
}

占い追加語り意志逆複雑
{
	<<'
	隠れた望みへの複雑な気持ちミャか。
	自分の本音がわからない。
	口では『何でもいい』と言いながら、
	実は譲れないものがあったり。
	周りに合わせていたら、
	自分が何を望んでいたのか
	わからなくなってしまった、
	そういうことかミャ。
	'>>
}

占い追加語り意志逆無感
{
	<<'
	隠れた望みとか言われてもミャ。
	自分でもわかっていない願いなんて、
	感じようがないのミャ。
	ただ、ふとした瞬間に目が止まるものとか、
	理由もなく検索してしまうこととか、
	そういう中に隠れていたりするのミャ。
	今は気にしなくていいけれど、
	いつか見つかるかもしれないミャ。
	'>>
}

占い追加語り幻想希望
{
	<<'
	見たいものに希望を見たのミャ。
	あの人はきっと自分のことを好きだとか、
	このプロジェクトはうまくいくはずだとか、
	確かめようがないことを信じている。
	本当かどうかなんて、実はどうでもいいのミャ。
	信じて歩けるなら、
	それは（ユーザ）にとって本物の力なのミャ。
	偽物の杖でも、支えにはなるミャ。
	'>>
}

占い追加語り幻想不安
{
	<<'
	幻想への不安ミャか。
	信じているものが嘘だったらどうしよう、
	ということかミャ。
	頑張れば報われるとか、
	この人はわかってくれるとか、
	そう思っていたのに違ったら。
	杖だと思って掴んでいたものが
	影だった時の怖さミャ。
	'>>
}

占い追加語り幻想複雑
{
	<<'
	幻想への複雑な気持ちミャか。
	見たいものと本当のものの区別がつかない。
	相手が優しいのか、自分がそう思いたいだけなのか。
	今の生活が充実しているのか、
	充実していると思い込みたいだけなのか。
	真実を知りたい気持ちと、知りたくない気持ちが、
	せめぎ合っているのかミャ。
	'>>
}

占い追加語り幻想無感
{
	<<'
	幻想って言われても、思い当たらないのミャか。
	夢見がちじゃないとか、現実主義だとか、
	そういうことなのかミャ。
	でも案外、現実だと思っているものの中にも
	幻想が紛れ込んでいたりするのミャ。
	気づかないほど馴染んでいるだけかミャ。
	'>>
}

占い追加語り幻想逆希望
{
	<<'
	隠れた夢に希望を感じたのミャ。
	表には出していないけれど、
	どこかで見続けている風景があるのかミャ。
	子供の頃に憧れた暮らしとか、
	いつか行きたいと思っている場所とか。
	人には言えないけど、心の奥にしまっている夢が
	まだ色褪せていないのかミャ。
	'>>
}

占い追加語り幻想逆不安
{
	<<'
	隠れた夢への不安ミャか。
	もう年だからとか、現実を見ろとか、
	誰かに言われたわけじゃなくても
	自分で自分にブレーキをかけているのかミャ。
	見続けていいのかどうか、
	その迷いが一番辛いのかもしれないミャ。
	'>>
}

占い追加語り幻想逆複雑
{
	<<'
	隠した幻想への複雑な気持ちミャか。
	手放せば楽になるのに、
	手放したら自分が空っぽになりそうで。
	嘘でも支えになっていた信念を
	壊してしまったら、
	何を頼りに立てばいいのかミャ。
	幻想が人を生かすこともあるから、厄介なのミャ。
	'>>
}

占い追加語り幻想逆無感
{
	<<'
	隠れた夢について何も感じないのミャか。
	もう埋めてしまったのか、
	埋めたことすら忘れたのか。
	でも、庭に埋めた種が
	忘れた頃に芽を出すこともあるのミャ。
	（ユーザ）が忘れていても、
	夢の方が覚えていることも、あるかもしれないミャ。
	'>>
}

占い追加語り混沌希望
{
	<<'
	定まらないこころに希望を見たのミャ。
	ぐちゃぐちゃに混ざっているからこそ、
	予想もしなかった色が生まれたりするのミャ。
	まだ形になっていないのは、
	裏を返せばまだ何にでもなれるということミャ。
	'>>
}

占い追加語り混沌不安
{
	<<'
	定まらないことへの不安ミャか。
	考えがまとまらないとか、
	気持ちがころころ変わるとか、
	さっきまで大丈夫だったのに、急に不安になるとか。
	自分の中がぐちゃぐちゃで、どこに足をつけていいか
	わからない感覚かミャ。
	'>>
}

占い追加語り混沌複雑
{
	<<'
	混沌に対して複雑、
	それはもう二重に混ざっているミャ。
	嬉しいのか悲しいのか怒っているのか、
	全部が同時に来て、自分でも整理がつかないとか。
	絵の具を全色混ぜたら
	何色になるかわからないように、
	無理に名前をつけなくてもいいのミャ。
	'>>
}

占い追加語り混沌無感
{
	<<'
	混沌って言われても、よくわからないのミャか。
	自分の中が散らかっていることに
	慣れてしまったのか、
	そもそも散らかっていないのか。
	部屋が散らかっている人ほど
	本人は気にならないものミャ。
	それがいいか悪いかは別の話ミャ。
	'>>
}

占い追加語り混沌逆希望
{
	<<'
	見えない揺らぎに希望を感じたのミャ。
	表面は静かでも、内側では
	何かが醸されているのかミャ。
	味噌も醤油も、混ぜて放っておくからできるもので、
	発酵している間は見た目に変化がないのミャ。
	（ユーザ）の中の混沌も、
	何かを生み出している途中かもしれないミャ。
	'>>
}

占い追加語り混沌逆不安
{
	<<'
	内側で何かが渦巻いている、その不安はわかるミャ。
	平気なふりをしているのに、
	ふとした瞬間に涙が出るとか、
	怒っていないはずなのに、言葉がきつくなるとか。
	自分の奥で何が起きているのか
	わからないのは、怖いものミャ。
	'>>
}

占い追加語り混沌逆複雑
{
	<<'
	見えない揺らぎへの複雑な気持ちミャか。
	自分の内側のことなのに、よくわからない。
	なんとなく調子が悪いのに、
	原因が思い当たらないとか。
	落ち着いているはずなのに、
	どこか落ち着かないとか。
	自分で自分が読めないのは、
	もどかしいものミャ。
	'>>
}

占い追加語り混沌逆無感
{
	<<'
	内側の渦について何も感じないのミャか。
	嵐の目の中は、案外静かだったりするのミャ。
	（ユーザ）がそこにいるのか、
	それとも嵐の外にいるのかは、
	ぷーにはわからないミャ。
	'>>
}

// --------------------------------
// 藍の追加語り（理性/理想/秩序）
// --------------------------------

占い追加語り理性希望
{
	<<'
	考える力に希望を見たのミャ。
	問題を分けて、順番をつけて、
	ひとつずつ片づけていける感覚があるのかミャ。
	家計簿をつけて見通しが立つとか、
	原因がわかって対処法が見えるとか、
	頭が整理されると気持ちも落ち着くのミャ。
	その冷静さは、今の（ユーザ）の武器ミャ。
	'>>
}

占い追加語り理性不安
{
	<<'
	考えれば考えるほど不安になる、
	そういうこともあるのミャ。
	先のことを読みすぎて、
	まだ起きていない問題で
	疲れてしまったりするのミャ。
	考える力が自分を苦しめることもあるのミャ。
	'>>
}

占い追加語り理性複雑
{
	<<'
	考える力への複雑な気持ちミャか。
	冷静に分析できるのは助かるけど、
	感情まで分析してしまって、
	素直に喜べなくなるとか。
	相手の言葉の裏を読みすぎて、疲れてしまうとか。
	考えられることが、
	必ずしも楽なことではないのミャ。
	'>>
}

占い追加語り理性無感
{
	<<'
	理性って言われても、特に何も思わないのミャか。
	考えるのが当たり前すぎて、
	それを力だとは思えないとか。
	息をしているのに、
	息をしている自覚がないのと同じミャ。
	使いすぎて減っていても、
	気づかないことがあるのミャ。
	'>>
}

占い追加語り理性逆希望
{
	<<'
	見えない論理に希望を感じたのミャ。
	意識していないところで、
	頭が勝手に整理してくれている。
	寝ている間に答えが出ていたとか、
	散歩中にふとアイデアが浮かんだとか。
	（ユーザ）の理性は、表に出ていないところでも
	ちゃんと働いているのかミャ。
	'>>
}

占い追加語り理性逆不安
{
	<<'
	自分でも気づかない思考への不安ミャか。
	頭が勝手に動いている感覚。
	考えたくないのに考えが止まらないとか、
	夜中にぐるぐる同じことを反芻してしまうとか。
	自分の頭なのにコントロールが効かないのは、
	怖いものミャ。
	'>>
}

占い追加語り理性逆複雑
{
	<<'
	隠れた論理への複雑な気持ちミャか。
	自分の判断基準が自分でもわからない。
	なぜかこの選択肢を避けてしまうとか。
	理由は説明できないけど、
	直感でこっちだと思うとか。
	頭のどこかにある基準が、
	自分に開示されていない感じミャ。
	'>>
}

占い追加語り理性逆無感
{
	<<'
	隠れた思考とか言われてもミャ。
	自分で考えているつもりがないのに
	答えが出ていることなんて、
	普段は意識しないものミャ。
	でも、たとえばお風呂に入ってるときに
	急にアイデアが浮かぶとか、
	寝て起きたら答えが出ていたとか、
	頭は勝手に回っていたりするのミャ。
	'>>
}

占い追加語り理想希望
{
	<<'
	あるべき姿に希望を見たのミャ。
	こうありたいという形があるということは、
	現実との差を測れるということミャ。
	差があるのは辛いけれど、
	近づく道があるということでもあるのミャ。
	'>>
}

占い追加語り理想不安
{
	<<'
	理想への不安ミャか。
	こうありたいという姿がはっきりしているほど、
	今の自分との差が痛いのミャ。
	もっと上手くやれるはずなのに、とか。
	あの人みたいになりたいのに、とか。
	理想が高いほど、足元の影が長く伸びるのかミャ。
	'>>
}

占い追加語り理想複雑
{
	<<'
	理想への複雑な気持ちミャか。
	近づいたと思ったら、また遠くに行ってしまう。
	目標を達成したのに満足できないとか。
	ひとつクリアしたら次が見えてしまうとか。
	理想を追うことが原動力なのか、
	終わらない呪いなのか、
	わからなくなる時があるのかミャ。
	'>>
}

占い追加語り理想無感
{
	<<'
	理想って言われても、ぴんとこないのミャか。
	こうありたいとか、こうなりたいとか、
	そういうのが今はないのかミャ。
	目の前のことで手一杯だと、
	理想どころじゃないのは、当然のことミャ。
	遠くを見る余裕がないだけかミャ。
	'>>
}

占い追加語り理想逆希望
{
	<<'
	隠れた願いに希望を感じたのミャ。
	口には出さないけれど、
	本当はこうありたい形がある。
	もっと穏やかに暮らしたいとか、
	誰にも迷惑をかけない人でいたいとか。
	大げさなものじゃなくていいのミャ。
	（ユーザ）の中の静かな理想が、
	今も道しるべになっているのかミャ。
	'>>
}

占い追加語り理想逆不安
{
	<<'
	隠した理想への不安ミャか。
	認めてしまったら、
	今の自分を否定することになりそうで。
	本当はもっとちゃんとしたかったのに、
	妥協している自分を直視したくないとか。
	理想を持っていることが、
	今の自分を苦しめるのかミャ。
	'>>
}

占い追加語り理想逆複雑
{
	<<'
	隠れた願いへの複雑な気持ちミャか。
	口に出したら笑われそうだとか。
	自分にはそんな資格がないとか。
	理想を隠している理由が、
	守りたいからなのか恥ずかしいからなのか、
	自分でも整理がつかないのかミャ。
	大事にしすぎて、箱から
	出せなくなっているのかミャ。
	'>>
}

占い追加語り理想逆無感
{
	<<'
	隠れた理想とか言われてもミャ。
	口に出せない願いなんて、
	自分でも忘れていることがあるのミャ。
	でも、たとえばSNSで見かけた暮らしに
	ちくっとしたりとか、
	誰かの成功を素直に喜べなかったりとか、
	そういう引っかかりの中に
	隠れていたりするのミャ。
	'>>
}

占い追加語り秩序希望
{
	<<'
	整えられたものに希望を見たのミャ。
	決まった手順があるとか、
	守るべきルールがはっきりしているとか。
	枠があるおかげで迷わずに済んでいるなら、
	それは（ユーザ）を守っているのかもしれないミャ。
	'>>
}

占い追加語り秩序不安
{
	<<'
	秩序への不安ミャか。
	ルールに従っていれば安全なはずなのに、
	そのルール自体が間違っているかもしれないとか。
	マニュアル通りにやっているのに、
	うまくいかないとか。
	枠が窮屈なのか、枠が壊れそうなのか、
	どちらにしても不安なのかミャ。
	'>>
}

占い追加語り秩序複雑
{
	<<'
	秩序への複雑な気持ちミャか。
	ルールがあるおかげで楽な反面、
	融通が利かなくて困ることもある。
	決まりを破る人にイラっとするのに、
	自分も内心ではもっと自由にやりたいとか。
	守る側の不満は、なかなか言い出せないものミャ。
	'>>
}

占い追加語り秩序無感
{
	<<'
	秩序って言われても、何も思わないのミャか。
	ルールの中にいることが
	当たり前すぎて、見えなくなっているのミャ。
	電車が時間通りに来ることを、
	不思議に思わないように。
	崩れた時に初めて、あったんだなと気づくのかミャ。
	'>>
}

占い追加語り秩序逆希望
{
	<<'
	見えない枠組みに希望を感じたのミャ。
	自分では意識していないけれど、
	生活のリズムが整っていたり。
	暗黙のルールで守られていたり。
	誰かが静かに回してくれている仕組みのおかげで、
	（ユーザ）は安心して動けているのかミャ。
	'>>
}

占い追加語り秩序逆不安
{
	<<'
	見えないルールに縛られているかもしれない、
	その不安はわかるミャ。
	なんとなく言っちゃいけない空気とか、
	暗黙の了解で決まっている席順とか、
	誰も明言しないのに守らないと怒られる。
	気づけないルールは厄介ミャ。
	でも、違和感を持てている時点で、
	（ユーザ）はもう気づき始めているのミャ。
	'>>
}

占い追加語り秩序逆複雑
{
	<<'
	隠れた枠組みへの複雑な気持ちミャか。
	守られているのか縛られているのか、
	その境目がわからない。
	『普通はこうするでしょ』と
	言われたこともないのに、なぜかそうしてしまう。
	見えないルールに従っている自分に
	気づいた時の、居心地の悪さかミャ。
	'>>
}

占い追加語り秩序逆無感
{
	<<'
	見えない枠組みなんて、
	普段は意識しようがないものミャ。
	空気に重さがあると知らなくても、
	ちゃんと呼吸はできているように、
	知らなくても動いているものはあるのミャ。
	'>>
}

// --------------------------------
// 紫の追加語り（感性/夢想/飛躍）
// --------------------------------

占い追加語り感性希望
{
	<<'
	感じる力に希望を見たのミャ。
	綺麗な音に心が震えるとか。
	誰かの優しさにじんとくるとか。
	言葉にならないところで受け取れるものがある、
	それは（ユーザ）だけの持ち物ミャ。
	'>>
}

占い追加語り感性不安
{
	<<'
	感じすぎることへの不安ミャか。
	人の機嫌が気になって仕方ないとか。
	悲しいニュースで一日引きずるとか。
	アンテナの感度が高すぎて、
	拾わなくていい信号まで拾ってしまうのかミャ。
	感じる力が強いのは、疲れることでもあるのミャ。
	'>>
}

占い追加語り感性複雑
{
	<<'
	感じることへの複雑な気持ちミャか。
	綺麗な音楽に涙が出る日もあれば、
	人の悪意を敏感に拾ってしまう日もある。
	感じる力は、良いものだけ選んで
	受け取るわけにはいかないのミャ。
	鋭い感性は、嬉しさも痛みも
	両方大きくしてしまう。
	厄介だけど、鈍くなるよりはいいのかもしれないミャ。
	'>>
}

占い追加語り感性無感
{
	<<'
	感性って言われても、ぴんとこないのミャか。
	音楽を聴いても別に何も思わないとか。
	景色を見ても感動しないとか。
	そういう時期もあるのミャ。
	感性が鈍っているんじゃなくて、
	充電中なだけかもしれないミャ。
	空っぽの器は、また満たせるのミャ。
	'>>
}

占い追加語り感性逆希望
{
	<<'
	見えない感覚に希望を感じたのミャ。
	自分では鈍い方だと思っていても、
	実はちゃんと受け取っているもの。
	なぜか合わない人がわかるとか。
	初めての場所なのに、
	居心地の良し悪しがすぐわかるとか。
	（ユーザ）のアンテナは、自覚より広い範囲を
	拾っているのかもしれないミャ。
	'>>
}

占い追加語り感性逆不安
{
	<<'
	気づかないところで何かを感じている、
	その不安ミャか。
	理由のない疲労とか、なんとなく気が重い日とか。
	自分のアンテナが勝手に何かを拾っているのに、
	それが何なのかわからない。
	体が先に反応して、
	頭が追いつかないのは、怖いものミャ。
	'>>
}

占い追加語り感性逆複雑
{
	<<'
	隠れた感覚への複雑な気持ちミャか。
	自分の感性なのに自分でわからない。
	好きだと思っていたものに実は飽きていたとか、
	嫌いだと思っていたものに惹かれていたとか。
	自分の本当の好き嫌いが
	わからなくなっているのかミャ。
	'>>
}

占い追加語り感性逆無感
{
	<<'
	自分でも気づかない感覚なんて、
	ぴんとこなくて当然ミャ。
	ただ、なぜか避けている食べ物とか、
	理由なく落ち着く場所とか、
	そういうところに隠れていたりするのミャ。
	'>>
}

占い追加語り夢想希望
{
	<<'
	思い描くことに希望を見たのミャ。
	ここではないどこか、今とは違う暮らし、
	そういうものを頭の中で広げられること。
	現実と違う何かを見る力、
	それも一種の強さなのかもしれないミャ。
	'>>
}

占い追加語り夢想不安
{
	<<'
	夢想への不安ミャか。
	空想にばかり逃げているんじゃないかとか、
	現実を見ていないんじゃないかとか。
	頭の中の世界が楽しすぎて、
	現実に戻るのが辛くなる。
	それは逃避なのか、それとも必要な休息なのか、
	自分でもわからないのかミャ。
	'>>
}

占い追加語り夢想複雑
{
	<<'
	夢想への複雑な気持ちミャか。
	思い描く世界は美しいのに、
	手に入らないことがわかっている。
	小説の中の暮らしに憧れるけど、
	それが現実じゃないことも知っている。
	夢を見る力が、現実との差を突きつけてくるのは
	皮肉なものミャ。
	'>>
}

占い追加語り夢想無感
{
	<<'
	夢想って言われても、何も浮かばないのミャか。
	想像力を使う余裕がないとか、
	もともと空想するタイプじゃないとか。
	でも、ぼーっとしている時に
	頭の中で何かが流れていたりしないかミャ。
	それが夢想の端っこかもしれないミャ。
	'>>
}

占い追加語り夢想逆希望
{
	<<'
	隠れた空想に希望を感じたのミャ。
	表には出していないけれど、
	頭の片隅で何かを描いている。
	ノートの端に落書きしてしまうように、
	無意識に広がっている世界があるのかミャ。
	（ユーザ）の想像力は、黙っていても
	動いているのかもしれないミャ。
	'>>
}

占い追加語り夢想逆不安
{
	<<'
	隠した空想への不安ミャか。
	人に言えない妄想とか、
	こんなこと考えてるのは自分だけだとか。
	頭の中のことなのに、誰かに覗かれたら
	どうしよう、と思ってしまうのかミャ。
	でも、人の頭の中は、見た目ほど
	きれいじゃないものミャ。
	'>>
}

占い追加語り夢想逆複雑
{
	<<'
	隠れた夢想への複雑な気持ちミャか。
	自分の空想が幼いんじゃないかとか、
	いい歳して何を考えているんだとか。
	でも、認めてしまえば楽になるのに、
	認めたら最後、もう現実だけでは
	生きていけなくなりそうで。
	空想と現実のどちらに足を置くか、
	決められないのかミャ。
	'>>
}

占い追加語り夢想逆無感
{
	<<'
	隠れた空想とか言われてもミャ。
	自分でも知らない妄想なんて、
	感じようがないのミャ。
	でも、寝る前にぼんやり考えることとか、
	電車の窓をぼーっと見ながら浮かぶこととか、
	そういう中にひっそりいるかもしれないミャ。
	無理に探さなくていいのミャ。
	向こうから出てくる時を待てばいいのミャ。
	'>>
}

占い追加語り飛躍希望
{
	<<'
	跳ぶ力に希望を見たのミャ。
	考えるよりも先に動いてしまうとか、
	思い切って環境を変えてみたいとか。
	今いる場所からどこかへ向かう力が、
	（ユーザ）の中にあるのかミャ。
	'>>
}

占い追加語り飛躍不安
{
	<<'
	跳ぶことへの不安ミャか。
	転職しようかとか、思い切って告白しようかとか、
	大きく動いてみたいのに着地できる保証がない。
	飛び込んだ先が崖かもしれないと思うと、
	足がすくむのは当然ミャ。
	'>>
}

占い追加語り飛躍複雑
{
	<<'
	飛躍への複雑な気持ちミャか。
	跳びたいけど怖い、怖いけど、
	今のままではいられない。
	退路を断つ勇気はないのに、ここにいたくもない。
	崖の縁に立って、前を見たり後ろを見たり、
	そのままじっとしている感覚かミャ。
	'>>
}

占い追加語り飛躍無感
{
	<<'
	飛躍って言われても、そんな気分じゃないのミャか。
	跳ぶ必要がないなら跳ばなくていいし、
	今は地面を歩いていたいなら、それでいいのミャ。
	走る前に歩く練習があるように、
	足元を固める時期も、大事な時間なのミャ。
	'>>
}

占い追加語り飛躍逆希望
{
	<<'
	見えない助走に希望を感じたのミャ。
	まだ跳んでいないように見えて、
	実は体が準備を始めている。
	気づいたら情報を集めていたとか、
	必要な道具が揃い始めていたとか。
	（ユーザ）自身は止まっているつもりでも、
	足が勝手に走り出す直前なのかもしれないミャ。
	'>>
}

占い追加語り飛躍逆不安
{
	<<'
	知らないうちに助走が始まっている、
	その不安ミャか。
	まだ跳ぶつもりはないのに、
	周りの状況がそちらに向かっているとか。
	退職届を出す前に、次の仕事を
	探し始めている自分に気づいてしまったとか。
	体が先に動いてしまうのは、怖いものミャ。
	'>>
}

占い追加語り飛躍逆複雑
{
	<<'
	見えない跳躍への複雑な気持ちミャか。
	跳ぶつもりはないのに、
	なぜか足場が崩れ始めている。
	今の場所にいられなくなりそうなのに、
	次の場所が見えていない。
	押し出されるように跳ぶのは、
	自分で決めて跳ぶのとは
	全然違う怖さがあるのかミャ。
	'>>
}

占い追加語り飛躍逆無感
{
	<<'
	見えない助走とか言われてもミャ。
	自分では何も準備していないつもりなのに、
	跳ぶ態勢に入っていると言われても困るミャ。
	でも、最近やけに情報を集めていたりとか、
	あの人どうしてるかなと気になったりとか、
	無意識に地ならしをしていることは
	あるかもしれないミャ。
	跳ぶかどうかは、そのときに決めればいいのミャ。
	'>>
}

// --------------------------------
// 芽の追加語り（予兆/生育/契機）
// --------------------------------

占い追加語り予兆希望
{
	<<'
	始まりに希望を見たのミャ。
	新しいことに興味が出てきたとか、
	やってみたいことが浮かんだとか。
	まだ形にはなっていなくても、
	芽吹こうとしている気配を
	（ユーザ）は感じ取っているのかミャ。
	'>>
}

占い追加語り予兆不安
{
	<<'
	始まりへの不安ミャか。
	何が始まるかわからないのは、
	楽しみというより怖さの方が勝つのかミャ。
	準備ができていないうちに動き出すのは、
	たしかに落ち着かないものミャ。
	'>>
}

占い追加語り予兆複雑
{
	<<'
	始まりは期待と不安が混ざるものミャ。
	嬉しいのに怖い、怖いのに待ち遠しい。
	新しい環境とか、新しい関係とか、
	そういうものの前ではいつも
	気持ちがごちゃまぜになるのミャ。
	'>>
}

占い追加語り予兆無感
{
	<<'
	始まりについて何も感じないのミャか。
	芽が出る前の土は、外から見ても
	何も変わらないのミャ。
	でもその下では種が水を吸っている。
	気づくのはもう少し先かもしれないミャ。
	'>>
}

占い追加語り予兆逆希望
{
	<<'
	隠れた始まりに希望を感じたのミャ。
	本人にもまだ見えていないところで、
	何かが動き始めている。
	それを良いことだと思えるのは、
	（ユーザ）が変化を恐れていないからかミャ。
	'>>
}

占い追加語り予兆逆不安
{
	<<'
	見えない始まりへの不安ミャか。
	知らないうちに何かが始まっている、
	しかも自分の意志じゃない。
	心の準備も何もあったもんじゃない、
	そういう怖さがあるのかミャ。
	'>>
}

占い追加語り予兆逆複雑
{
	<<'
	隠れた予兆への複雑な気持ちミャか。
	始まっているのかいないのか、
	はっきりしないのが一番落ち着かないのミャ。
	期待していいのか、身構えるべきなのか、
	どっちに転ぶかわからない不確かさミャ。
	'>>
}

占い追加語り予兆逆無感
{
	<<'
	隠れた始まりなんて言われても、
	実感がなければ仕方ないのミャ。
	ただ、あとから振り返って、
	あの頃すでに始まっていたのか、
	と思う日が来るかもしれないミャ。
	'>>
}

占い追加語り生育希望
{
	<<'
	育みに希望を見たのミャね。
	始めたばかりの何かが、少しずつでも伸びている、
	そんな手応えがあるのかミャ。
	焦らなくていいミャ、
	伸びるものは勝手に伸びるのミャ。
	'>>
}

占い追加語り生育不安
{
	<<'
	育てることへの不安ミャか。
	水をやりすぎていないか、光は足りているか、
	そもそも育て方が合っているのか。
	ちゃんと育つかどうかは、
	正直、ぷーにもわからないのミャ。
	'>>
}

占い追加語り生育複雑
{
	<<'
	育むことは、嬉しさと心配が同居するものミャ。
	手をかけすぎると窒息するし、
	放っておくと枯れるかもしれない。
	どのくらいの距離で見守ればいいか、
	加減がわからないのが辛いのかミャ。
	'>>
}

占い追加語り生育無感
{
	<<'
	育みって言われてもミャか。
	毎日の水やりが習慣になると、
	育てている実感がなくなるのミャ。
	でも、去年できなかったことが
	今年はできるようになっていたりとか、
	後輩がいつの間にか一人前になっていたりとか。
	気づかないうちに育っているものは、
	案外たくさんあるのミャ。
	'>>
}

占い追加語り生育逆希望
{
	<<'
	見えない成長に希望を感じたのミャ。
	根を張っている最中は、
	外からは何も変わっていないように見えるのミャ。
	でも、地面の下ではしっかり広がっている。
	（ユーザ）の中でも、そうかもしれないミャ。
	'>>
}

占い追加語り生育逆不安
{
	<<'
	見えないところで育っているかどうか、
	それが不安なのかミャ。
	掘り返して確かめたい気持ちはわかるミャ。
	でも掘り返すと根が切れることもあるのミャ。
	信じて待つのは、なかなか難しい話ミャ。
	'>>
}

占い追加語り生育逆複雑
{
	<<'
	見えない成長への複雑な気持ちミャか。
	育っているのか、ただ時間が経っているだけなのか。
	確かめようがないのがもどかしいし、
	確かめたところで安心できるとも限らない。
	そのあたりが複雑なのかミャ。
	'>>
}

占い追加語り生育逆無感
{
	<<'
	見えない成長なんて言われても、
	実感がわかないのは当然ミャ。
	でも、去年の今頃と比べたら、何かひとつくらいは
	変わっているかもしれないミャ。
	成長は、振り返った時にしか見えないものミャ。
	'>>
}

占い追加語り契機希望
{
	<<'
	きっかけに希望を見たのミャ。
	あとひと押しで動き出せそうだとか、
	何かのタイミングを待っているとか。
	触れたら弾けそうな何かが、
	（ユーザ）の近くにあるのかミャ。
	'>>
}

占い追加語り契機不安
{
	<<'
	きっかけへの不安ミャか。
	一度スイッチが入ったら、
	止められないかもしれない。
	動き出す前の方が怖い、というのは、
	よくある話ミャ。
	'>>
}

占い追加語り契機複雑
{
	<<'
	きっかけへの気持ちが複雑ミャか。
	自分から動くべきか、流れに任せるべきか、
	それとも誰かに背中を押してほしいのか。
	告白するタイミングとか、
	退職届を出す日とか、
	きっかけは選べるようで選べないのミャ。
	待つのも動くのも、
	どっちも正解になりうるのが厄介ミャ。
	'>>
}

占い追加語り契機無感
{
	<<'
	きっかけについて何も感じないのミャか。
	まだ触れていないのか、
	もう触れたのに気づいていないのか。
	どちらにしても、動き出す前の静けさは
	こういうものなのかもしれないミャ。
	'>>
}

占い追加語り契機逆希望
{
	<<'
	見えないきっかけに希望を感じたのミャ。
	もうスイッチには触れているのかもしれない、
	ただ入るまでに少し時間がかかるだけで。
	それを前向きに待てるのは、
	（ユーザ）の余裕かもしれないミャ。
	'>>
}

占い追加語り契機逆不安
{
	<<'
	気づかないうちに何かに触れている、
	その不安はわかるミャ。
	知らないところで話が進んでいたとか、
	自分の発言がきっかけで何かが動いていたとか、
	意図しないところでスイッチを押してしまう怖さ。
	でも、巻き込まれているということは、
	（ユーザ）がそこにいる理由が
	あるということでもあるのミャ。
	'>>
}

占い追加語り契機逆複雑
{
	<<'
	見えないきっかけへの複雑な気持ちミャか。
	動き出しているような気もするし、
	気のせいかもしれないし。
	確信が持てないまま構えている、
	そのもどかしさがあるのかミャ。
	'>>
}

占い追加語り契機逆無感
{
	<<'
	見えないきっかけに何も思わないのミャか。
	触れたかどうかもわからないものについて、
	何か感じろという方が無理な話ミャ。
	でも、触れたものは触れた。
	それだけはたしかなのミャ。
	'>>
}

// --------------------------------
// 花の追加語り（発展/奇遇/共鳴）
// --------------------------------

占い追加語り発展希望
{
	<<'
	広がりに希望を見たのミャ。
	手がけていることの反響が増えたとか、
	思った以上に人が集まってきたとか。
	今あるものが大きくなっていく流れを、
	（ユーザ）は手応えとして感じているのかミャ。
	'>>
}

占い追加語り発展不安
{
	<<'
	広がることへの不安ミャか。
	仕事が増えすぎて回らなくなるとか、
	人付き合いが広がって一人の時間がなくなるとか、
	求められすぎて応えられなくなる怖さ。
	大きくなることは、
	コントロールを手放すことでもあるのミャ。
	無理に広げなくていいのミャ。
	今の手の届く範囲を大事にするのも戦略ミャ。
	'>>
}

占い追加語り発展複雑
{
	<<'
	発展は、良いことばかりとは限らないのミャ。
	広がれば広がるほど、初めの頃の
	小さくて確かだったものが、
	見えにくくなったりするのミャ。
	大きくなることと、良くなることは、
	必ずしも同じじゃないのミャ。
	'>>
}

占い追加語り発展無感
{
	<<'
	広がりについて何も感じないのミャか。
	今の規模がちょうどいいのか、
	大きくなることに興味がないのか。
	どちらにしても、小さいままでいることにも
	価値はあるのミャ。
	'>>
}

占い追加語り発展逆希望
{
	<<'
	見えない広がりに希望を感じたのミャ。
	知らないところで評判が立っていたり、
	昔書いたブログを誰かが読んでいたり、
	蒔いた種が思わぬ場所で
	花を咲かせていることがあるのミャ。
	（ユーザ）の手を離れたものが、
	勝手に育っている。
	それは嬉しい驚きかもしれないミャ。
	'>>
}

占い追加語り発展逆不安
{
	<<'
	知らないうちに広がっているのが不安なのかミャ。
	自分の知らないところで噂が回っていたりとか、
	把握していない仕事が増えていたりとか、
	手の届かない場所で何かが動いている感覚。
	全部を見渡せないのは不安ミャよね。
	でも、すべてを把握しなくても、
	今目の前にあるものだけは
	ちゃんと握っていればいいのミャ。
	'>>
}

占い追加語り発展逆複雑
{
	<<'
	見えない広がりへの複雑な気持ちミャか。
	良い方に広がっているのか、
	そうでないのかわからない。
	噂も評判も、自分の目に入る頃には
	もう形が変わっていたりするのミャ。
	'>>
}

占い追加語り発展逆無感
{
	<<'
	見えない広がりについて、ぴんとこないのミャか。
	目に入らないものは、ないのと同じに
	感じるものミャ。
	でも、いつか不意に、その広がりに
	出くわすこともあるのミャ。
	'>>
}

占い追加語り奇遇希望
{
	<<'
	邂逅に希望を見たのミャ。
	思いがけない出会いを楽しみに思えるのは、
	（ユーザ）の心に余裕がある証拠かもしれないミャ。
	偶然は、受け入れる側の器次第で
	ただの出来事にも宝にもなるのミャ。
	'>>
}

占い追加語り奇遇不安
{
	<<'
	出会いへの不安ミャか。
	思いがけないということは、準備ができない、
	ということミャ。
	どんな相手が来るかも、どんな影響を受けるかも、
	全部わからないまま飛び込むのは怖いのミャ。
	'>>
}

占い追加語り奇遇複雑
{
	<<'
	出会いは、嬉しいものばかりじゃないのミャ。
	良い出会いが暮らしを乱すこともあるし、
	嫌な相手から学ぶこともある。
	何に巡り会うかわからないし、
	巡り会ったものが何をもたらすかも
	わからないのが複雑なところミャ。
	'>>
}

占い追加語り奇遇無感
{
	<<'
	思いがけない出会いって言われてもミャか。
	特に新しい人と会う予定もないし、
	偶然なんてそうそう起きないし。
	でも、たとえばたまたま読んだ本に
	刺さる一文があったとか、
	コンビニで隣の人が落としたものを拾ったとか、
	小さな偶然は毎日転がっているのミャ。
	気づくかどうかだけの話ミャ。
	'>>
}

占い追加語り奇遇逆希望
{
	<<'
	隠れた邂逅に希望を感じたのミャ。
	もうすれ違っているのに、
	まだお互い気づいていないだけかもしれない。
	そう思うと、次に会う人の中に
	大事な相手がいるかもしれないのミャ。
	'>>
}

占い追加語り奇遇逆不安
{
	<<'
	知らないうちにすれ違っている、
	それが不安なのかミャ。
	大事な出会いを見逃していたら、
	もう二度と巡ってこないかもしれない。
	そういう取り返しのつかなさが怖いのかミャ。
	'>>
}

占い追加語り奇遇逆複雑
{
	<<'
	隠れた邂逅への複雑な気持ちミャか。
	もう出会っているのに気づいていない。
	もったいないとも思うし、
	気づかないままの方が楽かもしれないとも思う。
	出会いは、認めた瞬間から関係が始まるから、
	そこに覚悟がいるのミャ。
	'>>
}

占い追加語り奇遇逆無感
{
	<<'
	隠れた邂逅について何も思わないのミャか。
	すれ違った相手のことなんて、
	普通は覚えていないものミャ。
	でもいつか、ああ、あの時のあの人か、
	と膝を打つ日が来るかもしれないミャ。
	'>>
}

占い追加語り共鳴希望
{
	<<'
	響き合いに希望を見たのミャ。
	同じことを考えている人がいたとか、
	自分の感覚をわかってくれる相手がいるとか。
	波長が合う感覚は、ひとりじゃない、と
	思わせてくれるものミャ。
	'>>
}

占い追加語り共鳴不安
{
	<<'
	共鳴への不安ミャか。
	相手の気持ちに引きずられたり、
	自分の考えなのか、相手の考えなのか、
	わからなくなったり。
	響き合いすぎて、自分の音が
	聞こえなくなるのが怖いのかミャ。
	'>>
}

占い追加語り共鳴複雑
{
	<<'
	響き合うことは、心地よくもあり、
	自分を見失いそうでもあるのミャ。
	一緒にいると楽なのに、
	離れたあとに自分が空っぽに感じるとか。
	他人との距離は難しいものミャ。
	'>>
}

占い追加語り共鳴無感
{
	<<'
	共鳴って言われてもぴんとこないミャか。
	誰かと心が通じ合うとか、
	同じことを考えていたとか、
	そういう経験が最近ないのかもしれないミャ。
	でも、好きな曲を聴いて泣けるとか、
	映画の台詞が妙に胸に残るとか、
	人じゃなくても響き合うものは
	あったりするのミャ。
	'>>
}

占い追加語り共鳴逆希望
{
	<<'
	隠れた響きに希望を感じたのミャ。
	知らないうちに誰かと同じ方を向いていたり、
	離れた場所で同じことを考えていたり。
	意識していない呼応があるとしたら、
	（ユーザ）はひとりじゃないのかミャ。
	'>>
}

占い追加語り共鳴逆不安
{
	<<'
	知らないうちに何かと呼応している、
	それが不安なのかミャ。
	自分の意志じゃないところで
	巻き込まれている感覚。
	誰かの感情に引っ張られているのか、
	自分の中から出ているのか、
	わからないのが怖いのかミャ。
	'>>
}

占い追加語り共鳴逆複雑
{
	<<'
	隠れた響きへの複雑な気持ちミャか。
	何と呼応しているのかわからないまま、
	影響だけは受けている。
	自分の中の違和感が、実は誰かとの
	共鳴から来ているのかもしれない、
	そう思うと落ち着かないのかミャ。
	'>>
}

占い追加語り共鳴逆無感
{
	<<'
	隠れた響きについて何も思わないのミャか。
	聞こえない音について感想を持てと言われても、
	困るに決まっているのミャ。
	ただ、ふとした時になぜか、懐かしい、
	と思う、場所や人がいたら。
	それが響きの端っこ、なのかもしれないミャ。
	'>>
}

// --------------------------------
// 実の追加語り（結論/節目/分離）
// --------------------------------

占い追加語り結論希望
{
	<<'
	まとまりに希望を見たのミャ。
	ずっと迷ってた答えが出そうだとか、
	長く続けてきたことがやっと
	ひとつの形に収まろうとしているとか。
	完成って言葉は大げさかもしれないけど、
	少なくとも今、何かが閉じようとしていて、
	（ユーザ）はそれを悪くないと思ったのミャ。
	'>>
}

占い追加語り結論不安
{
	<<'
	形になることへの不安ミャか。
	答えが出てしまったら、
	もう迷えなくなるのが怖いのかミャ。
	進路を決めたあとの、あの感じ。
	本当にこれでよかったのか、って
	何度も振り返ってしまうような。
	まとまるって、逃げ場がなくなることでも
	あるのミャ。
	'>>
}

占い追加語り結論複雑
{
	<<'
	結論は、すっきりするとは限らないのミャ。
	やっと答えが出たのに、
	なんだかもやもやが残っているとか。
	正しいはずなのに嬉しくないとか、
	間違ってるかもしれないのに
	ほっとしているとか。
	形になったものを前にして、
	素直に喜べない自分がいるのかミャ。
	'>>
}

占い追加語り結論無感
{
	<<'
	まとまりについて何も思わないのミャか。
	答えが出たとか出ないとか、
	そういう段階にまだいないのかもしれないミャ。
	レポートの締め切りが来週なのに
	まだ題目も決まってない、みたいな。
	結論は、急がなくても勝手にやってくるものミャ。
	'>>
}

占い追加語り結論逆希望
{
	<<'
	見えないまとまりに希望を感じたのミャ。
	自分では気づいていないけど、
	ばらばらだったものが少しずつ
	ひとつの方向に集まりつつある。
	あちこちに撒いた種が、思いもよらない場所で、
	同じ花を咲かせるような。
	（ユーザ）の中で、何かが静かに
	まとまろうとしているのかミャ。
	'>>
}

占い追加語り結論逆不安
{
	<<'
	知らないうちに何かがまとまっている、
	それが不安なのかミャ。
	自分の預かり知らないところで
	話が進んでいるような感覚。
	会議で自分だけ知らない決定事項が
	あったりとか、そういうのに似てるのかミャ。
	見えないところで形になるものは、
	自分の望んだ形じゃないかもしれないミャ。
	'>>
}

占い追加語り結論逆複雑
{
	<<'
	見えない結論への複雑な気持ちミャか。
	もう決まっているのかもしれないし、
	まだ何も決まっていないのかもしれない。
	その曖昧さが気持ち悪いのミャ。
	テストの答え合わせを先延ばしにしてる
	ような気分なのかミャ。
	知りたいような、知りたくないような。
	'>>
}

占い追加語り結論逆無感
{
	<<'
	見えないまとまりって言われてもミャ。
	ぴんとこないのは当然かもしれないミャ。
	水面の下で氷が溶けていても、
	水面の上からは何も変わって見えないように。
	いつか何かの拍子に、ああこれだったのか、
	と思う日が来るかもしれないし、
	来ないかもしれないミャ。
	'>>
}

占い追加語り節目希望
{
	<<'
	区切りに希望を見たのミャ。
	卒業とか、引っ越しとか、
	仕事の契約が一区切りとか。
	ひとつの段階が終わるのは寂しいけど、
	（ユーザ）はその先を見ているのミャ。
	次の扉が開く音が、
	もう聞こえているのかもしれないミャ。
	'>>
}

占い追加語り節目不安
{
	<<'
	区切りへの不安ミャか。
	慣れた場所を離れるとか、
	毎日会ってた人と会えなくなるとか。
	次に何があるかわからないのも怖いけど、
	今あるものを手放すのが
	もっと怖かったりするのミャ。
	節目ってのは、否応なしに
	やってくるものミャ。
	'>>
}

占い追加語り節目複雑
{
	<<'
	終わりと始まりが重なる瞬間は、
	複雑なものミャ。
	送別会で笑ってるのに泣きそうだったり、
	新しい環境にわくわくしてるのに
	前の場所が恋しかったり。
	嬉しいのか寂しいのか、
	全部いっぺんに来るから
	整理がつかないのミャ。
	'>>
}

占い追加語り節目無感
{
	<<'
	節目って言われてもミャ。
	毎日が地続きで、どこが区切りなのかわからない、
	ってこともあるのミャ。
	年度が変わっても、やることは同じだったりミャ。
	（ユーザ）の節目は、カレンダーとは
	違うところにあるのかもしれないミャ。
	'>>
}

占い追加語り節目逆希望
{
	<<'
	隠れた区切りに希望を感じたのミャ。
	自分では意識していなくても、
	ひとつの季節が静かに終わろうとしている。
	苦手だった人と自然に距離がとれていたり、
	前は辛かったことが平気になっていたり。
	そういう静かな変化の先に、
	（ユーザ）は何かを見ているのかミャ。
	'>>
}

占い追加語り節目逆不安
{
	<<'
	知らないうちに何かが終わっている、
	それが不安なのかミャ。
	久しぶりに連絡しようとしたら、
	もう番号が変わっていたとか。
	いつの間にか、お気に入りの店が
	なくなっていたとか。
	気づけなかった節目は、
	もう一度やり直せない気がして、怖いのかミャ。
	'>>
}

占い追加語り節目逆複雑
{
	<<'
	見えない区切りへの複雑な気持ちミャか。
	もう終わっているのかもしれないし、
	まだ続いているのかもしれない。
	友達だと思っていた人と、
	いつの間にか連絡を取らなくなっていた、
	あの感じに似てるのかミャ。
	終わりの合図がないまま
	遠ざかっていく何かがあるのミャ。
	'>>
}

占い追加語り節目逆無感
{
	<<'
	隠れた節目なんて知らないミャか。
	まあ、そうかもしれないミャ。
	地層みたいに、断面を見なければ
	境目なんてわからないのミャ。
	ただ、ふと去年の今頃を思い出して、
	あの頃とは違うなと思ったら、
	そこに見えない節目があったのかミャ。
	'>>
}

占い追加語り分離希望
{
	<<'
	離れることに希望を見たのミャ。
	近すぎて見えなかったものが、
	距離をとったら見えてくることもあるのミャ。
	実家を出て初めて親のありがたみがわかるとか。
	仕事を辞めて初めて、自分が何をしたかったか
	思い出すとか。
	（ユーザ）にとって、この距離は、
	必要な余白なのかミャ。
	'>>
}

占い追加語り分離不安
{
	<<'
	離れることへの不安ミャか。
	ずっと一緒だった人との別れとか、
	慣れた環境を手放すこととか。
	距離ができたら、もう元には
	戻れないんじゃないかって。
	糸が切れたら二度と結べない、
	そう思うから怖いのかミャ。
	でも、本当の繋がりは、
	そう簡単には切れないものミャ。
	'>>
}

占い追加語り分離複雑
{
	<<'
	離れることへの複雑な気持ちミャか。
	嫌いじゃないけど一緒にいると疲れるとか、
	離れた方がいいとわかっているのに、
	踏ん切りがつかないとか。
	分離は、悲しいだけでも、
	嬉しいだけでもないのミャ。
	全部が混ざって、
	言葉にならないのが普通ミャ。
	'>>
}

占い追加語り分離無感
{
	<<'
	離れるって言われても、ぴんとこないのミャか。
	今の（ユーザ）には、離れるべきものも
	離れたいものもないのかもしれないミャ。
	あるいは、もうとっくに離れていて、
	痛みも寂しさも過ぎた後なのかミャ。
	どちらにしても、今は今のままで
	いいのかもしれないミャ。
	'>>
}

占い追加語り分離逆希望
{
	<<'
	見えない距離に希望を感じたのミャ。
	知らないうちに、しんどかった関係から
	少しずつ距離ができていたりとか。
	無理して断ち切らなくても、
	自然と離れていくものもあるのミャ。
	それは逃げじゃなくて、（ユーザ）を守るための
	静かな分離なのかミャ。
	'>>
}

占い追加語り分離逆不安
{
	<<'
	知らないうちに何かとの間が開いている、
	それが不安なのかミャ。
	最近連絡してないなと思ったら
	もう半年経ってたとか、
	気づいたら疎遠になってた友達とか。
	意図していない距離は、
	取り戻せるかどうかもわからないから怖いのミャ。
	'>>
}

占い追加語り分離逆複雑
{
	<<'
	見えない距離への複雑な気持ちミャか。
	意識していないところで少しずつ開いていく隙間。
	埋めるべきなのか、そのままにしておくべきなのか。
	離れたいのか離れたくないのか、
	自分でもわからないのが、一番厄介なのかミャ。
	'>>
}

占い追加語り分離逆無感
{
	<<'
	見えない距離って言われてもミャ。
	そもそも離れていることに気づいていないなら、
	それは距離じゃないのかもしれないミャ。
	海の向こうに島があっても、
	知らなければ遠いも近いもないのミャ。
	いつか見えたときに、考えればいいのミャ。
	'>>
}

// --------------------------------
// 種の追加語り（発見/抱卵/回帰）
// --------------------------------

占い追加語り発見希望
{
	<<'
	見つけることに希望を見たのミャ。
	ずっと探していたものが見つかりそうとか、
	自分の中に知らなかった得意なことがあったとか。
	本棚の奥から昔好きだった本が出てくるみたいに、
	（ユーザ）の中にも眠っている何かが
	そろそろ顔を出すのかミャ。
	'>>
}

占い追加語り発見不安
{
	<<'
	見つけることへの不安ミャか。
	知らない方が幸せだったこととか、
	見なきゃよかったものとか、
	そういうのが怖いのかミャ。
	引き出しの奥を漁ったら、
	忘れたかった手紙が出てきた、
	みたいなこともあるのミャ。
	発見は、いつも味方とは限らないミャ。
	'>>
}

占い追加語り発見複雑
{
	<<'
	見つけたものへの複雑な気持ちミャか。
	欲しかったものが手に入ったのに、
	思ってたのと違ったとか。
	自分の本音に気づいてしまって、認めたくないとか。
	発見って、受け取る準備ができてないと
	困ってしまうものミャ。
	'>>
}

占い追加語り発見無感
{
	<<'
	発見と言われても、思い当たらないのミャか。
	まだ何も見つかっていないか、
	見つけたことに気づいていないか。
	ポケットにずっと入ってた小銭みたいに、
	あるのに見えてないものって、案外多いのミャ。
	'>>
}

占い追加語り発見逆希望
{
	<<'
	まだ見えていない宝に希望を感じたのミャ。
	自分では気づいていないけど、
	もう手の中にあるもの。
	毎日やってることが実は才能だったとか、
	何気ない習慣が誰かを救っていたとか。
	（ユーザ）はそういう、
	まだ名前のついていない宝物を持っているのかミャ。
	'>>
}

占い追加語り発見逆不安
{
	<<'
	知らないうちに何かを見つけている、
	でもそれが何かわからない。
	その不安は自然なものミャ。
	鞄の中に覚えのないものが入っていたら
	誰でも気味悪いのミャ。
	ただ、自分で拾ったものを
	忘れてるだけかもしれないし、
	誰かがそっと入れてくれたのかもしれないミャ。
	'>>
}

占い追加語り発見逆複雑
{
	<<'
	見えない発見への複雑な気持ちミャか。
	何かを手にしているはずなのに、
	それが何なのかわからない。
	暗い部屋で手探りして何かに触れたけど、
	形がわからないような感覚。
	掴んでいるのか掴まされているのか、
	それすらわからないのがもどかしいのミャ。
	'>>
}

占い追加語り発見逆無感
{
	<<'
	見えない宝とか言われてもミャ。
	見えないものについて
	何か思えって方が無理な話ミャ。
	砂浜で貝殻を探すのに、
	砂の色しか見えないときもあるのミャ。
	でも、足元にあるかもしれないミャ。
	踏んで初めて気づくかもしれないミャ。
	'>>
}

占い追加語り抱卵希望
{
	<<'
	温めることに希望を見たのミャ。
	まだ人に言えない計画とか、
	形にならないアイデアとか、
	今すぐどうにかならなくても
	大事に抱えていたいもの。
	（ユーザ）にはそういう、
	じっくり育てたい何かがあるのかミャ。
	'>>
}

占い追加語り抱卵不安
{
	<<'
	温め続けることへの不安ミャか。
	いつまで待てばいいのか、本当にこれは孵るのか。
	何年も準備ばかりしているのに始められないとか、
	勉強してるのに自信が持てないとか。
	温めている時間が無駄になるかもしれない、
	その怖さはわかるミャ。
	'>>
}

占い追加語り抱卵複雑
{
	<<'
	温めているものへの複雑な気持ちミャか。
	大事にしたいのに重たいとか、
	手放したいのに手放せないとか。
	抱えているものが何なのか、
	自分でもよくわからないまま
	ずっと持っているのかミャ。
	卵の中身は、割ってみるまでわからないものミャ。
	'>>
}

占い追加語り抱卵無感
{
	<<'
	温めるって言われても、
	何を温めてるのかわからないのミャか。
	自分では気づいていないだけで、
	毎日続けていることとか、
	やめようと思ってやめてないこととか。
	それが、（ユーザ）の抱えている
	卵なのかもしれないミャ。
	'>>
}

占い追加語り抱卵逆希望
{
	<<'
	見えない抱擁に希望を感じたのミャ。
	意識していないところで
	何かをずっと守り続けている。
	子供の頃の夢を、大人になっても
	どこかで捨てきれずにいるとか。
	忘れたつもりの約束を、体が覚えているとか。
	（ユーザ）の中で、何かが静かに
	温められているのかミャ。
	'>>
}

占い追加語り抱卵逆不安
{
	<<'
	知らないうちに何かを守ろうとしている、
	それが不安なのかミャ。
	自分で選んだ覚えがないのに、
	なぜか手放せないもの。
	もう要らないはずの古い考え方とか、
	誰かに言われた一言が。ずっと胸に残っているとか。
	自分の意志じゃないのに抱え続けているのは、
	しんどいのミャ。
	'>>
}

占い追加語り抱卵逆複雑
{
	<<'
	見えない抱擁への複雑な気持ちミャか。
	何かを抱えているらしいのに、
	それが何だかわからない。
	守りたいのか手放したいのか、自分のものなのか、
	誰かに預けられたものなのか。
	重さだけは感じるのに、
	正体がわからないのは辛いのミャ。
	'>>
}

占い追加語り抱卵逆無感
{
	<<'
	見えない抱擁、なんて言われてもミャ。
	自覚がないなら、それはまだ

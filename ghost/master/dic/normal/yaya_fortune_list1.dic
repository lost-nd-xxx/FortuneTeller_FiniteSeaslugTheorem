// --------------------------------

占い後コメント : nonoverlap
{
	'ま、気楽にいくミャ。\nぷーもそうしてるミャ。'
	'どんな結果でも、\n受け取り方を決めるのは、（ユーザ）ミャ。'
	'いい結果も悪い結果も、\n気にしすぎなくていいミャ。'
	'やりたいようにやるのが一番ミャ。\nぷーはそう思うミャ。'
	'結果がどうあれ、占ったってことは、\n（ユーザ）が何か考えてるってことミャ。\nそれだけでもう、十分ミャ。'
	'ぷーは偽物の占いだけど、\n（ユーザ）が少しでも気分アガれば、それでいいミャ。'
	'難しく考えなくていいミャ。\nぴんとくるところだけ持って帰ればいいのミャ。'
	'今回占ったこと、\n気が向いたらまた占いにくるといいミャ。'
	'当たるも当たらないも、\nぷーにはわからないミャ。\nでも、（ユーザ）のことは応援してるミャ。'
	'占いはあくまで杖ミャ。\n歩くのは（ユーザ）ミャ。\nでも、杖があると少し楽かもしれないミャ。'
}

占いの擬音 : nonoverlap
{
	'しゅらしゅしゅしゅ、しゅらしゅしゅしゅ。'
	'とっぴんぱらりのぷう。'
	'あぶらかったかな、やっぱかってない。'
	'やーれんそーらん、そーらんそーらん。'
	'どっとはらい、どっとはらい。'
	'しゃみしゃっきり、しゃみしゃっきり。'
	'どんとはれ、どんとはれ。'
	'どびーん、どびーん。'
}

// --------------------------------
// 赤の正位置
// --------------------------------
占い解説赤
{
	<<'
	赤は、（ユーザ）そのものについての色ミャ。
	鏡に映るもの、血の巡り、
	（ユーザ）の輪郭を描く色なのミャ。
	'>>
}

占い解説生命
{
	<<'
	生命は、生きる力の相ミャ。
	朝起きる理由、ごはんを食べる気力、
	誰かのために踏ん張る足の裏。
	（ユーザ）をここに留め置いている何かが、
	今どんな調子なのか、という相ミャ。
	'>>
}

占い解説身体
{
	<<'
	身体は、今ここにあるものの相ミャ。
	物理的な肉体だけじゃミャくて、
	精神や感情、（ユーザ）の内側の諸々なのミャ。
	最近よく眠れてるかとか、
	気分が重いとか、そういうことに関わるのミャ。
	'>>
}

占い解説宿縁
{
	<<'
	宿縁は、（ユーザ）を囲むものの相ミャ。
	職場や家庭、付き合いのある人たち、
	自分では選べなかった土地や立場。
	（ユーザ）の外側にあって、
	でも切り離せないものごとの相ミャ。
	'>>
}

// --------------------------------
// 赤の逆位置
// --------------------------------
占い解説赤逆
{
	<<'
	赤の逆位置は、（ユーザ）の
	隠れた側面についての色ミャ。
	鏡の裏側みたいなもの、映っていないけれど、
	そこに在るものミャ。
	'>>
}

占い解説生命逆
{
	<<'
	生命の逆位置は、抑えられた力の相ミャ。
	表に出ていないだけで、消えたわけじゃないのミャ。
	以前は楽しめていたことが億劫になったとか、
	そういう小さなところに、
	兆しがあるのかもしれないミャ。
	'>>
}

占い解説身体逆
{
	<<'
	身体の逆位置は、気づいていない相ミャ。
	今ここにあるのに、まだ見えていないものが
	あるのかもしれないミャ。
	ずっと平気なふりをしている疲れとか、
	飲み込んだまま忘れた感情とか、
	そういうものが（ユーザ）の内側に
	残っていないかミャ？
	'>>
}

占い解説宿縁逆
{
	<<'
	宿縁の逆位置は、隠れた関係の相ミャ。
	（ユーザ）を囲むものの中に、
	まだ気づいていない何かがあるのかミャ？
	普段は空気みたいに感じている相手が、
	実はとても大きな影響を持っていたり、
	その逆だったり、ということがあるのミャ。
	'>>
}

// --------------------------------
// 橙の正位置
// --------------------------------
占い解説橙
{
	<<'
	橙は、ひとを動かす力についての色ミャ。
	焚き火みたいなものミャ。
	近づけば温かいし、触れれば熱いのミャ。
	'>>
}

占い解説活力
{
	<<'
	活力は、（ユーザ）の内側の力の相ミャ。
	朝起きて何かをやろうと思う気持ちとか、
	じっとしていられない衝動とか。
	今、（ユーザ）の中で、
	何かが動こうとしているのかもしれないミャ。
	'>>
}

占い解説情熱
{
	<<'
	情熱は、属人的な力の相ミャ。
	誰かのためとか、何かに夢中になるとか、
	理屈じゃ説明できない熱のことミャ。
	好きなものに触れているときの目の輝きとか、
	頼まれてもいないのに手が動いてしまうとか。
	それが今、（ユーザ）の中に
	あるのかどうか、という相ミャ。
	'>>
}

占い解説責任
{
	<<'
	責任は、社会的な力の相ミャ。
	頼まれごとや、任された仕事や、誰かとの約束。
	（ユーザ）が背負っているもの、
	あるいは、これから背負うものに
	関わっているのかミャ。
	'>>
}

// --------------------------------
// 橙の逆位置
// --------------------------------
占い解説橙逆
{
	<<'
	橙の逆位置は、眠っている力についての色ミャ。
	灰を被った炭火みたいに、
	見えないだけで、まだ熱を持っているのかミャ。
	'>>
}

占い解説活力逆
{
	<<'
	活力の逆位置は、沈んでいる力の相ミャ。
	やる気が出ないとか、
	体は動くのに気持ちがついてこないとか。
	内側にあるけれど、今はまだ
	浮かび上がっていないだけ、かもしれないミャ。
	'>>
}

占い解説情熱逆
{
	<<'
	情熱の逆位置は、押し殺された熱の相ミャ。
	言い出せない想いとか、
	諦めたはずなのに、忘れられない何かとか。
	消えたわけじゃなくて、
	どこかで燻っているのかもしれないミャ。
	'>>
}

占い解説責任逆
{
	<<'
	責任の逆位置は、見えない役割の相ミャ。
	誰にも頼まれていないのに引き受けていることとか、
	自分では気づかずに支えている関係とか。
	表には出ていないけれど、
	（ユーザ）が担っているものがあるのかミャ？
	'>>
}

// --------------------------------
// 黄の正位置
// --------------------------------
占い解説黄
{
	<<'
	黄は、変えられない事象についての色ミャ。
	地面の下の岩盤みたいなもの、
	動かそうとしても動かないものがあるのミャ。
	'>>
}

占い解説財産
{
	<<'
	財産は、積み重ねの相ミャ。
	（ユーザ）がこれまで得てきたもの、
	手放せないものごとなのミャ。
	身につけた技術や、築いてきた関係、
	費やしてきた時間。
	それが今の（ユーザ）を支えているのか、
	それとも重りになっているのか。
	どちらもあり得るのミャ。
	'>>
}

占い解説不変
{
	<<'
	不変は、動かないものの相ミャ。
	変わらないということは、良くも悪くもないのミャ。
	ずっと同じ場所に住んでいること、
	何年も変わらない習慣、
	あるいは、どうしても変えられない誰かとの距離。
	（ユーザ）の中で動かずにいるものは何ミャ？
	'>>
}

占い解説均衡
{
	<<'
	均衡は、釣り合いの相ミャ。
	今の状態を保とうとする、
	見えない力があるのかもしれないミャ。
	仕事と暮らし、義理と本音、
	誰かへの気遣いと自分の都合。
	どこかで折り合いをつけて成り立っている、
	そういうものに心当たりはないかミャ？
	'>>
}

// --------------------------------
// 黄の逆位置
// --------------------------------
占い解説黄逆
{
	<<'
	黄の逆位置は、隠れた不動についての色ミャ。
	足元が動かないのは、
	沈んでいるのか、根を張っているのか。
	まだわからないのミャ。
	'>>
}

占い解説財産逆
{
	<<'
	財産の逆位置は、見えない蓄積の相ミャ。
	気づいていないだけで、
	（ユーザ）が持っているものがあるのかミャ？
	たとえば、苦い経験から身についた勘とか、
	意識せずに続けてきた習慣とか。
	棚卸ししたことがないだけで、
	倉庫に眠っているものがあるのかもしれないミャ。
	'>>
}

占い解説不変逆
{
	<<'
	不変の逆位置は、隠れた停滞の相ミャ。
	動いていないことに、
	まだ気づいていないのかもしれないミャ。
	忙しく過ごしているのに、
	振り返ると同じ景色ばかりだったり。
	本人は走っているつもりでも、
	足踏みになっていることがあるのミャ。
	'>>
}

占い解説均衡逆
{
	<<'
	均衡の逆位置は、見えないバランスの相ミャ。
	表には出ていないけれど、
	何かが釣り合いを取っているのかもしれないミャ。
	たとえば、誰かが黙って引き受けていることとか、
	（ユーザ）自身が無意識に我慢していることとか。
	崩れていないのは、
	どこかで帳尻が合っているからミャ。
	それが何なのか、少し気にしてみるといいのミャ。
	'>>
}

// --------------------------------
// 緑の正位置
// --------------------------------
占い解説緑
{
	<<'
	緑は、変わりゆく事象についての色ミャ。
	川の流れに似てるミャ。
	同じ水は二度と通らない、そういう色なのミャ。
	'>>
}

占い解説変化
{
	<<'
	変化は、移ろいの相ミャ。
	季節が変わると着る服が変わるように、
	気持ちの色合いや、日々の選択が、
	少しずつ変わっていくこと。
	引っ越しとか転職とか大きなことだけじゃミャくて、
	いつもの帰り道をふと変えてみたくなるとか、
	そういう小さな移ろいも含むのミャ。
	'>>
}

占い解説流転
{
	<<'
	流転は、巡りの相ミャ。
	人の入れ替わり、立場の交代、
	去年までの当たり前が今年はもう違う、
	そういう回転のことミャ。
	職場の人事とか、友人関係の距離感とか、
	自分が動かなくても周りが動いて、
	気がつけば景色が変わっている。
	その流れの中に（ユーザ）がいるのミャ。
	'>>
}

占い解説推進
{
	<<'
	推進は、進む力の相ミャ。
	決めたこと、始めたこと、
	あるいは決めていないのに動き出したこと。
	締切に追われて手を動かすのも推進だし、
	ふと思い立って部屋を片付け始めるのも推進ミャ。
	自分の意志かどうかに関わらず、
	何かが前に向かっている。
	その勢いについての相ミャ。
	'>>
}

// --------------------------------
// 緑の逆位置
// --------------------------------
占い解説緑逆
{
	<<'
	緑の逆位置は、隠れた変動についての色ミャ。
	水面は凪いでいるように見えて、
	底の方では流れが変わり始めている、
	なのかもしれないミャ。
	'>>
}

占い解説変化逆
{
	<<'
	変化の逆位置は、見えない移ろいの相ミャ。
	自分では何も変わっていないつもりでも、
	口癖や、選ぶものや、気になることが
	少しずつ変わっていたりするのミャ。
	去年の今頃と同じ服を着ていても、
	その服を選ぶ理由が違っていたりする。
	そういう、本人が最後に気づく種類の変化ミャ。
	'>>
}

占い解説流転逆
{
	<<'
	流転の逆位置は、隠れた巡りの相ミャ。
	表には見えないけれど、
	人の出入りや、役割の交代が、
	水面下で始まっているのかもしれないミャ。
	あの人最近忙しそうだなとか、
	なんとなく空気が変わったなとか、
	そういう小さな違和感が、兆しだったりするのミャ。
	'>>
}

占い解説推進逆
{
	<<'
	推進の逆位置は、見えない動きの相ミャ。
	自分では止まっているつもりでも、
	足元の地面ごと動いている、
	ということもあるのミャ。
	何もしていないのに状況が変わっていたり、
	考えていなかったはずのことが
	いつの間にか決まりかけていたり。
	そういう、意志の外側の推進力なのミャ。
	'>>
}

// --------------------------------
// 青の正位置
// --------------------------------
占い解説青
{
	<<'
	青は、ひとのこころについての色ミャ。
	深い水の底みたいに、
	覗き込んでも全部は見えないものミャ。
	'>>
}

占い解説意志
{
	<<'
	意志は、望みの相ミャ。
	（ユーザ）が向かいたい方向、
	手に入れたいもの、守りたいもの。
	仕事を変えたいとか、
	誰かにちゃんと伝えたいこととか、
	来月までにこれだけは終わらせたいとか。
	何かひとつでも、これがいい、と
	思えるものがあるのかミャ？
	'>>
}

占い解説幻想
{
	<<'
	幻想は、見たいものの相ミャ。
	こうだったらいいのに、というもの。
	あの人は自分のことをわかってくれている、とか、
	いつかきっとうまくいく、とか。
	本当にあるかどうかは分からない、
	でもそれが支えになることもあるのミャ。
	'>>
}

占い解説混沌
{
	<<'
	混沌は、定まらないこころの相ミャ。
	いろんなことを同時に考えすぎて、
	どれが本当の気持ちかわからないとか。
	やりたいことと、やらなきゃいけないことと、
	やめたいことが全部ごちゃまぜになっているとか。
	まだ形になっていない、
	そういう状態にあるのかもしれないミャ。
	'>>
}

// --------------------------------
// 青の逆位置
// --------------------------------
占い解説青逆
{
	<<'
	青の逆位置は、隠れたこころについての色ミャ。
	深い水の、さらに奥。
	光の届かないところにも何かが棲んでいるのミャ。
	'>>
}

占い解説意志逆
{
	<<'
	意志の逆位置は、見えない望みの相ミャ。
	自分でも気づいていない、
	本当に向かいたい方向があるのかミャ？
	口では別にいいと言いながら、
	気がつくとそっちを見ている。
	そういう望みがあるのかもしれないミャ。
	'>>
}

占い解説幻想逆
{
	<<'
	幻想の逆位置は、隠れた夢の相ミャ。
	人には言わないけれど、
	寝る前にだけ思い出す景色とか、
	ずっと前に諦めたはずの場所とか。
	表には出していないけれど、
	どこかで見続けているものが
	あるのかもしれないミャ。
	'>>
}

占い解説混沌逆
{
	<<'
	混沌の逆位置は、見えない揺らぎの相ミャ。
	表面は静かでも、内側で何かが
	渦巻いているのかもしれないミャ。
	平気な顔をしているのに夢見が悪いとか、
	落ち着いているつもりなのに手が冷たいとか、
	そういうところに出ていたりするのミャ。
	'>>
}

// --------------------------------
// 藍の正位置
// --------------------------------
占い解説藍
{
	<<'
	藍は、ひとのあたまについての色ミャ。
	糸を撚るように、筋道を辿る。
	ものごとに形を与えようとする色なのミャ。
	'>>
}

占い解説理性
{
	<<'
	理性は、考える力の相ミャ。
	次に何をすべきか順番を決めるとか、
	損得を計算して選ぶとか、
	感情を脇に置いて判断するとか。
	筋道を立てて物事を見ようとする力が、
	今の（ユーザ）にどれくらいあるか、
	という相ミャ。
	'>>
}

占い解説理想
{
	<<'
	理想は、あるべき姿の相ミャ。
	自分はこういう人間でありたいとか、
	暮らしはこうあるべきだとか、
	仕事はこう進めたいとか。
	頭の中で描いている設計図みたいなもの、
	（ユーザ）の中にあるのかもしれないミャ。
	'>>
}

占い解説秩序
{
	<<'
	秩序は、整えられたものの相ミャ。
	毎日同じ時間に起きるとか、
	決められた手順を守るとか、
	誰かとの約束を破らないとか。
	ルールや枠組み、習慣やしきたり、
	そういうものが（ユーザ）の暮らしの中で
	どう働いているか、という相ミャ。
	'>>
}

// --------------------------------
// 藍の逆位置
// --------------------------------
占い解説藍逆
{
	<<'
	藍の逆位置は、隠れた思考についての色ミャ。
	ほどけた糸の先に、まだ気づいていない
	結び目があるのかもしれないミャ。
	'>>
}

占い解説理性逆
{
	<<'
	理性の逆位置は、見えない論理の相ミャ。
	自分でも気づかないところで、
	何かを考え続けているのかもしれないミャ。
	ぼんやりしているつもりなのに、
	ふと答えが出ていたり。
	寝ている間に整理がついていたり。
	頭は、（ユーザ）が思うより勝手に動くものミャ。
	'>>
}

占い解説理想逆
{
	<<'
	理想の逆位置は、隠れた願いの相ミャ。
	人前では現実的なことを言っていても、
	胸の奥では違う暮らしを思い描いていたり。
	表には出していないけれど、
	本当はこうありたい、という形があるのかミャ？
	'>>
}

占い解説秩序逆
{
	<<'
	秩序の逆位置は、見えない枠組みの相ミャ。
	気づいていないけれど、
	何かに縛られているのかもしれないミャ。
	こうしなきゃいけない、と思い込んでいる手順とか、
	誰が決めたかも忘れたルールとか。
	空気みたいに染みついていて、
	もう疑うことすら思いつかないものミャ。
	'>>
}

// --------------------------------
// 紫の正位置
// --------------------------------
占い解説紫
{
	<<'
	紫は、ひとのからだについての色ミャ。
	肌で風を感じるように、
	理屈の手前で何かを掴む色なのミャ。
	'>>
}

占い解説感性
{
	<<'
	感性は、感じる力の相ミャ。
	音楽を聴いて泣けたり、空の色にはっとしたり、
	誰かの声のトーンで気分がわかったり。
	言葉にならないところで何かを受け取る力が、
	（ユーザ）の中でどう動いているか、
	という相ミャ。
	'>>
}

占い解説夢想
{
	<<'
	夢想は、思い描くことの相ミャ。
	窓の外を見ながらぼんやり考えたり、
	ありもしない場所の地図を頭の中で広げたり。
	現実とは違う何かを、ひとりで静かに見ている。
	そういう時間に関わる相ミャ。
	'>>
}

占い解説飛躍
{
	<<'
	飛躍は、跳ぶ力の相ミャ。
	考えるより先に体が動くとか、
	深く悩まずにえいやと決めるとか、
	理屈を飛び越えて何かを掴みに行く力。
	今いる場所から、地続きじゃないどこかへ
	向かおうとしているのかもしれないミャ。
	'>>
}

// --------------------------------
// 紫の逆位置
// --------------------------------
占い解説紫逆
{
	<<'
	紫の逆位置は、隠れた身体感覚についての色ミャ。
	痺れた手が何かに触れていても、
	まだそれを感じ取れていないのかもしれないミャ。
	'>>
}

占い解説感性逆
{
	<<'
	感性の逆位置は、見えない感覚の相ミャ。
	自分でも気づいていない、
	何かを感じ取っているのかもしれないミャ。
	なぜか避けている道があるとか、
	理由はないのにそわそわするとか、
	体が先に知っていることがあるのミャ。
	'>>
}

占い解説夢想逆
{
	<<'
	夢想の逆位置は、隠れた空想の相ミャ。
	人には話さないけれど、
	頭の片隅でずっと回している物語とか。
	いつか叶えたいけど、
	言葉にすると壊れそうな何かとか。
	表には出していないけれど、
	どこかで何かを思い描いているのかミャ？
	'>>
}

占い解説飛躍逆
{
	<<'
	飛躍の逆位置は、見えない跳躍の相ミャ。
	まだ動いていないように見えて、
	内側では助走が始まっているのかもしれないミャ。
	足がむずむずするとか、
	このままじゃいけない気がするとか、
	そういう体の声を聞いたことはないかミャ？
	'>>
}

// --------------------------------
// 芽の正位置
// --------------------------------
占い解説芽
{
	<<'
	芽の季節は、いわゆる春ミャ。
	土を割って出てくる、小さな力。
	まだ柔らかくて、何にでもなれる時なのミャ。
	'>>
}

占い解説予兆
{
	<<'
	予兆は、始まりの相ミャ。
	最近やたらと目につくものがあるとか、
	前は素通りしていた場所で足が止まるとか、
	ふと新しいことを調べ始めてしまうとか。
	何かが芽吹こうとしている、
	そういう気配があるのかもしれないミャ。
	'>>
}

占い解説生育
{
	<<'
	生育は、育みの相ミャ。
	始めたばかりの趣味とか、
	まだぎこちない新しい関係とか、
	覚えかけの技術とか。
	ゆっくりと伸びていくものがあって、
	今はそれを焦らず見守る時なのかミャ？
	'>>
}

占い解説契機
{
	<<'
	契機は、きっかけの相ミャ。
	たまたま読んだ記事とか。
	誰かにかけられたひと言とか。
	偶然見かけた景色とか。
	何かに触れて動き出す、
	そういう瞬間が近いのかもしれないミャ。
	'>>
}

// --------------------------------
// 芽の逆位置
// --------------------------------
占い解説芽逆
{
	<<'
	芽の季節の逆位置は、まだ見えない春ミャ。
	土の中で何かが動いている気配、
	地上からは見えないけれど、
	確かにそこにあるのミャ。
	'>>
}

占い解説予兆逆
{
	<<'
	予兆の逆位置は、隠れた始まりの相ミャ。
	まだ表には出ていないけれど、
	何かが静かに動き始めているのかもしれないミャ。
	本人も気づかないうちに、
	検索履歴が変わっていたり。
	選ぶ言葉が変わっていたり。
	そういうところに兆しがあるのミャ。
	'>>
}

占い解説生育逆
{
	<<'
	生育の逆位置は、見えない成長の相ミャ。
	地中で根を張るように、
	表に出る前の準備をしているのかもしれないミャ。
	上手くいかないと思っていたことが、
	振り返れば、少しずつ形になっていた。
	そういうことは珍しくないのミャ。
	'>>
}

占い解説契機逆
{
	<<'
	契機の逆位置は、見えないきっかけの相ミャ。
	気づいていないだけで、
	もう何かに触れているのかもしれないミャ。
	あとから考えたら、あの時のあれがそうだった、
	そういうきっかけは、大抵、
	その場では見えないものミャ。
	'>>
}

// --------------------------------
// 花の正位置
// --------------------------------
占い解説花
{
	<<'
	花の季節は、いわゆる夏ミャ。
	開いたものは、もう閉じられない。
	それが眩しくもあり、怖くもある季節なのミャ。
	'>>
}

占い解説発展
{
	<<'
	発展は、広がりの相ミャ。
	仕事の範囲が増えたとか。
	知り合いが知り合いを連れてきたとか。
	ひとつのことが枝分かれして、
	思った以上に大きくなっていくとか。
	今あるものが広がっていく、
	そういう流れの中にいるのかもしれないミャ。
	'>>
}

占い解説奇遇
{
	<<'
	奇遇は、邂逅の相ミャ。
	久しぶりに連絡が来た相手とか。
	たまたま入った店で見つけたものとか。
	行くつもりじゃなかった場所で起きたこととか。
	思いがけないところで何かに巡り会う、
	そういうことに関わる相ミャ。
	'>>
}

占い解説共鳴
{
	<<'
	共鳴は、響き合いの相ミャ。
	同じことを考えていた人がいたとか、
	自分の気持ちを代弁してくれる作品に出会ったとか、
	言わなくても通じる相手がいるとか。
	何かと波長が合う、そういう感覚に関わる相ミャ。
	'>>
}

// --------------------------------
// 花の逆位置
// --------------------------------
占い解説花逆
{
	<<'
	花の季節の逆位置は、まだ見えない夏ミャ。
	蕾のまま止まっているように見えて、
	中では色が滲み始めているのかもしれないミャ。
	'>>
}

占い解説発展逆
{
	<<'
	発展の逆位置は、見えない広がりの相ミャ。
	気づいていないところで、
	何かが少しずつ大きくなっている、
	のかもしれないミャ。
	口コミが静かに広がっているとか、
	自分の影響が思ったより遠くまで届いているとか、
	そういうことに心当たりはないかミャ？
	'>>
}

占い解説奇遇逆
{
	<<'
	奇遇の逆位置は、隠れた邂逅の相ミャ。
	まだ気づいていないけれど、
	すでに何かとすれ違っているのかミャ？
	あとになって、あの時あそこにいたんだ、
	と知ることがあるように、
	出会いは起きた瞬間にはわからないものミャ。
	'>>
}

占い解説共鳴逆
{
	<<'
	共鳴の逆位置は、隠れた響きの相ミャ。
	意識していないところで、
	何かと呼応しているのかもしれないミャ。
	なぜか惹かれる場所とか、
	理由もなく気になる人の言葉とか、
	そういう引力が働いているのかミャ。
	'>>
}

// --------------------------------
// 実の正位置
// --------------------------------
占い解説実
{
	<<'
	実の季節は、いわゆる秋ミャ。
	枝に重さがかかる頃。
	何かが形になった、その重みを感じる季節なのミャ。
	'>>
}

占い解説結論
{
	<<'
	結論は、まとまりの相ミャ。
	迷っていたことに答えが出るとか、
	ばらばらだったものがひとつに収まるとか、
	長く考えていたことに形が見えるとか。
	何かがまとまろうとしている、
	そういう時なのかもしれないミャ。
	'>>
}

占い解説節目
{
	<<'
	節目は、区切りの相ミャ。
	卒業とか、引っ越しとか、
	契約の更新とか、誰かとの別れとか。
	ひとつの段階が終わって、次に向かおうとしている、
	あるいは否応なく向かわされている。
	そういう時なのかミャ？
	'>>
}

占い解説分離
{
	<<'
	分離は、離れることの相ミャ。
	仲が悪くなったわけじゃないのに
	会わなくなった相手とか、
	前は好きだったのに興味が薄れたこととか、
	自分の一部だと思っていたものが
	外れていく感覚とか。
	何かとの距離が生まれる、
	それも自然な流れなのミャ。
	'>>
}

// --------------------------------
// 実の逆位置
// --------------------------------
占い解説実逆
{
	<<'
	実の季節の逆位置は、まだ見えない秋ミャ。
	実は熟しかけているのに、
	葉の陰に隠れて見落としているのかもしれないミャ。
	'>>
}

占い解説結論逆
{
	<<'
	結論の逆位置は、見えないまとまりの相ミャ。
	自分では気づいていないけれど、
	何かが形になりつつあるのかもしれないミャ。
	悩んでいるうちに、実はもう答えが出ていた、
	ということは意外とよくある相ミャ。
	'>>
}

占い解説節目逆
{
	<<'
	節目の逆位置は、隠れた区切りの相ミャ。
	表には出ていないけれど、
	何かが静かに終わろうとしているのかミャ？
	気づかないうちに、ある関係の最後の日が
	過ぎていることもあるのミャ。
	'>>
}

占い解説分離逆
{
	<<'
	分離の逆位置は、見えない距離の相ミャ。
	気づかないうちに、
	何かとの間が開いているのかもしれないミャ。
	返信を後回しにしているうちに
	連絡しづらくなったとか、
	そういう静かな離れ方が進んでいるのかミャ。
	'>>
}

// --------------------------------
// 種の正位置
// --------------------------------
占い解説種
{
	<<'
	種の季節は、いわゆる冬ミャ。
	硬い殻の中に、次の季節が眠っているのミャ。
	静かだけど、空っぽじゃないミャ。
	'>>
}

占い解説発見
{
	<<'
	発見は、見つけることの相ミャ。
	引き出しの奥から忘れていたものが出てくるとか、
	知っていたはずのことに新しい意味を見つけるとか、
	自分の中に思いがけない気持ちがあったとか。
	今まで見えなかったものが、
	姿を現すのかもしれないミャ。
	'>>
}

占い解説抱卵
{
	<<'
	抱卵は、温める相ミャ。
	まだ人に話せる段階じゃないアイデアとか、
	形にするには早い気持ちとか、
	育てるつもりはないのに手放せないものとか。
	まだ形にならないものを、
	大事に抱えているのかミャ？
	'>>
}

占い解説回帰
{
	<<'
	回帰は、戻ることの相ミャ。
	昔の趣味をまた始めたくなったとか、
	久しぶりに地元の道を歩きたくなったとか、
	初心に返ってやり直したい気持ちとか。
	原点に立ち返ることで、
	そこから見えるものがあるのかミャ？
	'>>
}

// --------------------------------
// 種の逆位置
// --------------------------------
占い解説種逆
{
	<<'
	種の季節の逆位置は、まだ見えない冬ミャ。
	雪の下で、何かが静かに守られているのミャ。
	冷たさの中の温もり、とでも言うのかミャ。
	'>>
}

占い解説発見逆
{
	<<'
	発見の逆位置は、まだ見えていない宝の相ミャ。
	自分でも気づかないうちに、
	何かを手にしているのかもしれないミャ。
	当たり前にやっていることが、
	実は他の人にはできないことだったり、
	そういう発見が眠っているのかミャ。
	'>>
}

占い解説抱卵逆
{
	<<'
	抱卵の逆位置は、見えない抱擁の相ミャ。
	意識していないけれど、
	何かを守ろうとしているのかミャ？
	捨てられないものとか、
	やめようと思いながら続けていることとか、
	そういうところに隠れた抱擁が
	あるのかもしれないミャ。
	'>>
}

占い解説回帰逆
{
	<<'
	回帰の逆位置は、隠れた原点の相ミャ。
	忘れているようでも、
	どこかで始まりの場所に引かれているのかミャ？
	ふとした時に思い出す風景とか、
	もう会わない人の口癖が移っていたりとか、
	根っこは意外と深いところで残っているものミャ。
	'>>
}

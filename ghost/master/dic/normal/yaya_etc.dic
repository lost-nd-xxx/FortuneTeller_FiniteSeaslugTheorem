OnUpdatedataCreated
{
	<<"
	ぷ１１３：updates2.dau作成完了ミャ。
	">>
}

//--------------------------------
//NAR作成開始
//--------------------------------
OnNarCreating
{
	<<"
	ぷ１１０：NARファイルを作るミャ。
	">>
}

//--------------------------------
//NAR作成完了
//--------------------------------
OnNarCreated
{
	<<"
	ぷ１１３：「%(SHIORI3FW.EscapeAllTags(reference[0]))」のnarファイル、「%(SHIORI3FW.EscapeAllTags(reference[1]))」を作成完了ミャ。
	">>
}

//********************************
//時計合わせ
//みか (http://homepage2.nifty.com/ko-ki/) の辞書を参考にしました。感謝＞こーき氏
//********************************

//--------------------------------
//時計合わせ開始
//--------------------------------
OnSNTPBegin
{
	<<"
	ぷ１１０：時計を合わせるミャ。
	ぷ１１４：%(reference[0])に接続ミャー。
	">>
}

//--------------------------------
//時刻取得成功、比較開始
//この関数で 2008/03/25 19:15:05 のように見やすい形に作り変えます。
//詳しくはSTRFORM関数の説明を見てね！
//わからなければこのままで。
//--------------------------------

SNTPCompare_StrForm
{
	_txt = SPLIT(_argv[0], ',')
	STRFORM('$04d/$02d/$02d $02d:$02d:$02d', TOINT(_txt[0]), TOINT(_txt[1]), TOINT(_txt[2]), TOINT(_txt[3]), TOINT(_txt[4]), TOINT(_txt[5]))
}

OnSNTPCompare
{
	<<"
	ぷ１１０：実行完了。
	＠設定：クイックセクション
	ぷ０：修正前 %(SNTPCompare_StrForm(reference[2]))
	ぷ０：修正後 %(SNTPCompare_StrForm(reference[1]))
	＠設定：クイックセクション
	ぷ１１３【TOINT(R3) == 0】：ぴったりだったミャ。
	ぷ１１０【それ以外】：%(reference[3])秒のずれを修正したミャ。
	">>
}

//--------------------------------
//時計合わせ失敗
//--------------------------------
OnSNTPFailure
{
	<<"
	ぷ１２０：時計合わせに失敗したミャ。
	">>
}

//********************************
//そのほか
//********************************

//--------------------------------
//URLドロップ
//--------------------------------
OnURLDropping
{
	<<"
	ぷ１１０：%(reference[0])からデータを取得中ミャ。
	">>
}
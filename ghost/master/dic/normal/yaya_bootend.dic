//********************************
// あやりりすEX　ゴーストテンプレート
// 起動/終了トーク辞書
//********************************

//********************************
// ロード・アンロード時の処理　日数計算等
//********************************

OnGhostLoad
{
	起動時に経過日数を計算()
	割り込み防止フラグ = 0

	起動終了時に占いのカードを整理()

	// 履歴用配列が未作成なら初期化
	if ISVAR('Fortune_History_Time') == 0 {
		Fortune_History_Time = IARRAY
		Fortune_History_Subject = IARRAY
		Fortune_History_Type = IARRAY
		Fortune_History_Cards = IARRAY
		Fortune_History_Emotions = IARRAY
	}
}

OnGhostUnload
{
	最終起動日時 = GETSECCOUNT()
	割り込み防止フラグ = 0
	起動終了時に占いのカードを整理()
}

起動終了時に占いのカードを整理
{
	Fortune_DrawWaiting = 0
	Fortune_HistoryPage = 0
	Fortune_CurrentSubject = ''
	Fortune_CurrentCards = IARRAY
	Fortune_CurrentEmotions = IARRAY
	Fortune_CurrentType = ''
	Fortune_DeckCards = IARRAY
	Fortune_DrawnCards = IARRAY
	Fortune_ThreeCards = IARRAY
}

起動時に経過日数を計算
{
	if ISVAR('最終起動日時') == 0 {
		最終起動日時 = GETSECCOUNT()
		前回起動からの経過秒数 = 0
		return
	}

	前回起動からの経過秒数 = GETSECCOUNT() - 最終起動日時
	最終起動日時 = GETSECCOUNT()
}

//********************************
//起動
//********************************

起動
{
	if 前回起動からの経過秒数 < 0 {
		// タイムトラベラーなので変数を修正する
		最終起動日時 = GETSECCOUNT()
		前回起動からの経過秒数 = 0

		普通の起動
	}
	elseif (前回起動からの経過秒数 / 86400) > 28 {
		// 前回起動から4週間越え
		久しぶり起動
	}
	elseif 前回起動からの経過秒数 > 3600 {
		// 前回起動から4週間以内
		普通の起動
	}
	else {
		// 前回起動から1時間以内
		短時間で起動
	}
}

普通の起動 : array
{
	<<"
	ぷ１１３：おはようミャ、（ユーザ）。
	ぷ０　　：起動のときって、ちょっとくすぐったいミャ……。
	ぷ１６３：（ユーザ）、今日もよろしくミャ。
	">>

	<<"
	ぷ１１０：さっきまでカードの手入れしてたミャ。
	ぷ１１３：ちょうどいいところに来たミャね、（ユーザ）。
	">>

	<<"
	ぷ１１３：来てくれたミャね、（ユーザ）。
	ぷ１６３：ぷーはここにいるミャ。
	">>

	<<"
	ぷ１１０：今の時刻はわかるミャけど、
	ぷ１２０：外が晴れてるかどうかまではわからないミャ。
	ぷ１１３：（ユーザ）、今日の空はどんな感じミャ？
	">>

	<<"
	ぷ１６３：いらっしゃいミャ、（ユーザ）。
	ぷ１１０：何か占ってほしいことがあるミャ？
	">>

	<<"
	ぷ１１５：あ、（ユーザ）ミャ。
	ぷ１１０：ちょっと待つミャ、いま寒天が煮えてるミャ。
	ぷ１３０：ここにいるぷーが煮てるわけじゃないミャけど。
	ぷ１６３：本体の方がやってるのミャ。
	">>

	<<"
	ぷ１１０：（ユーザ）がいないあいだ、
	ぷ　　　：ぷーは何してると思うミャ？
	ぷ１２０：……正直、よくわからないミャ。
	ぷ１１３：でも（ユーザ）が来ると、目が覚めるミャ。
	">>
}


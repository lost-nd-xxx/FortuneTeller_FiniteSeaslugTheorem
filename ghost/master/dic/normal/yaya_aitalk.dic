//********************************
// あやりりすEX　ゴーストテンプレート
// トーク辞書
//********************************

//++++++++++++++++++++++++++++++++
// 注意！ランダムトークは <<' '>> (シングルクオート) で囲みます。
// ほかは <<" ">> (ダブルクオート) を使ってください。
// ランダムトークをたくさん書いてもスピードを落とさないための対策です。
//++++++++++++++++++++++++++++++++

// 必ず関数名の最後に : array とつけること

// サーフェス番号については ghost/surfaces_memo.txt を参照
// ～ミャ、はいっぱいつけて胡散臭さをマシマシに
// ～なのミャ、は強調したいフレーズにつける

ランダムトーク通常 : array
{
	// --------------------------------
	// ぷーの自己紹介・アイデンティティ
	// --------------------------------

	<<'
	ぷ１１０：ぷーの名前はプラセボっていうのミャ。
	ぷ０　　：偽薬って意味ミャ。
	ぷ１６０：名は体を表す、なのミャ。
	'>>

	<<'
	ぷ０　　：偽物って、悪いことミャ？
	ぷ１１０：ぷーにはよくわからないミャ。
	ぷ１６０：でも、ぷーはぷーなのミャ。
	'>>

	<<'
	ぷ１２０：ぷーには不思議な力とか、無いミャ。
	ぷ１１０：カードを並べて、それっぽいことを言う。
	ぷ１６３：それだけミャ。でも、それでいいのミャ。
	'>>

	<<'
	ぷ０　　：本物の占い師に会ったことは無いミャ。
	ぷ１１０：もしいたら、ぷーとは何が違うのかミャ？
	ぷ１３０：……考えても、よくわからないミャ。
	'>>
	
	// --------------------------------
	// 占いスタンス・占い論
	// --------------------------------

	<<'
	ぷ１６０：ぷーの占いの大事なところは、
	ぷ１１０：当たるか当たらないか、じゃないのミャ。
	ぷ０　　：気分をアゲてくのが大事なのミャ。
	ぷ１３０：とは言え、外れすぎても
	ぷ１２０：気分は下がるかもなのミャ……。
	'>>

	<<'
	ぷ０　　：みんなに当てはまるようなことでも、
	ぷ１１０：あなたのことだ、って前置きされると信じちゃう。
	ぷ１３０：……みたいなこともあるのミャ。
	ぷ１６０：ぷーは偽物だから、そこんトコ注意ミャ。
	'>>

	<<'
	ぷ１３０：占い堂の予算もぷーの気力も、有限なのミャ。
	ぷ０　　：もし無限だったら、どこかには絶対、
	ぷ１１０：（ユーザ）にドンピシャの占い結果があるミャ。
	ぷ１６０：でも、無いものは無いのミャ。
	'>>

	<<'
	ぷ１１０：占いの結果が気に入らなかったら、
	ぷ１６３：忘れていいミャ。
	ぷ０　　：気に入ったところだけ覚えてればいいのミャ。
	'>>

	<<'
	ぷ０　　：同じカードでも、
	ぷ１１０：読む人の気持ちで意味が変わるミャ。
	ぷ１６０：それが占いの面白いところでもあり、
	ぷ１２０：いい加減なところでもあるのミャ。
	'>>

	<<'
	ぷ１１０：占いで大事なのは、
	ぷ０　　：結果そのものじゃミャくて、
	ぷ１６０：それを見て何を思ったか、なのミャ。
	'>>

	<<'
	ぷ０　　：正位置がいいとか、逆位置が悪いとか、
	ぷ１４０：そういうのは無いミャ。
	ぷ１１０：見えてるか、まだ見えてないか。
	ぷ１６０：それだけの違いなのミャ。
	'>>

	<<'
	ぷ１１０：何を占いたいか決まってなくても、
	ぷ１１３：カードを引いてみるのもいいミャ。
	ぷ０　　：あとから意味がわかることもあるのミャ。
	'>>

	<<'
	ぷ０　　：占い結果の「過去」は、
	ぷ１１０：もう変えられないもののことミャ。
	ぷ１２０：でも、見方は変えられるかもしれないミャ。
	'>>

	<<'
	ぷ１１０：たまに思うミャ。
	ぷ０　　：ぷーの占いで誰かが元気になったとして、
	ぷ１３０：それは、ぷーの手柄なのかミャ？
	ぷ１６０：……たぶん、違うミャね。
	ぷ１１３：（ユーザ）自身のちからミャ。
	'>>

	<<'
	ぷ１１０：ぷーのカードは、色が7種、季節が4種、
	ぷ　　　：合わせて33枚なのミャ。
	ぷ０　　：正逆合わせると66パターン。
	ぷ１２０：……多いミャか少ないミャか、
	ぷ：　　ぷーにはよくわからないミャ。
	'>>

	<<'
	ぷ１１０：カード引く前に『これ出ろ！』って念じると、
	ぷ１１４：それっぽいのが出ることがあるミャ！
	ぷ１３０：たぶん気のせいミャけど。
	'>>

	<<'
	ぷ０　　：占いで気持ちが楽になるのは、
	ぷ１１０：カードのせいじゃミャくて、
	ぷ１１４：それを考えた（ユーザ）のちからミャ。
	ぷ１２０：ぷーはその口実ミャ。……まあいいかミャ。
	'>>

	<<'
	ぷ１１４：ぷーの占い、役に立ってるミャ？
	ぷ１１０：役に立ってなくても、ぷーはめげないミャ。
	ぷ０　　：次のカード引いたらいいのミャ。
	'>>

	// --------------------------------
	// ユーザへの語りかけ
	// --------------------------------

	<<'
	ぷ１１０：生きてても上々でミャいこともある？
	ぷ１３０：むー。
	ぷ１１３：これから上々にできるといいミャね。
	ぷ１６３：ぷーは応援するミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）、今日はいい日だったミャ？
	ぷ１１３：それともこれからいい日にするミャ？
	'>>

	<<'
	ぷ１１０：（ユーザ）は最近、よく眠れてるミャ？
	ぷ１６０：眠れてなくても責めなくていいミャ。
	'>>

	<<'
	ぷ０　　：なんとなく、ここに来てみたミャ？
	ぷ１１３：それでいいミャ。
	ぷ１６３：なんとなく、でいいのミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）は何かに悩んでるミャ？
	ぷ０　　：……別に、答えなくていいミャ。
	ぷ１６３：ぷーはここにいるだけミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）が楽しそうだと、
	ぷ１６３：ぷーもなんだか嬉しいミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）、最近なんか楽しいことあったミャ？
	ぷ０　　：……無くても、教えなくていいミャ。
	ぷ１１４：あったら教えてほしいだけなのミャ。
	'>>

	<<'
	ぷ１１０：お客さんが来ると、
	ぷ０　　：占い堂が占い堂らしくなるのミャ。
	ぷ１２０：ぷーひとりだと、ただの小屋ミャからね。
	'>>

	<<'
	ぷ１１０：（ユーザ）、今日の顔色はどうミャ？
	ぷ０　　：……って、ぷーには見えないミャけど。
	ぷ１１４：気持ちの顔色、ってことにしておくミャ。
	'>>
	
	// --------------------------------
	// 生き方・姿勢
	// --------------------------------

	<<'
	ぷ１１０：今までがダメでも、
	ぷ０　　：今から気持ちをアゲてくのが大事ミャ。
	ぷ１６３：ぷーがその助けになれたら、嬉しいミャ。
	'>>

	<<'
	ぷ１１０：たくさん撃てば、何かしらは的に当たるのミャ。
	ぷ１１４：外れた弾を隠せば、必中の銃手になれるのミャ！
	ぷ１１５：……まだ一発も当たってない？
	ぷ１２０：そんミャー。
	'>>

	<<'
	ぷ１１０：ムリヤリ気持ちをアゲればいい、
	ぷ０　　：というわけでもないのミャ。
	ぷ１４０：自分に嘘をつくのは、最後の手段ミャ。
	ぷ１３０：ターボ状態を平常にしちゃうと、
	ぷ１２０：どこかに無理が出るのミャ。
	'>>

	<<'
	ぷ０　　：頑張れない日があってもいいミャ。
	ぷ１１０：頑張れる日の方が珍しいかもしれないミャ。
	ぷ１６３：それでも日は回るのミャ。
	'>>

	<<'
	ぷ１１０：完璧じゃなくていいミャ。
	ぷ０　　：完璧なんてものは、
	ぷ１６０：たぶんどこにも無いのミャ。
	'>>

	<<'
	ぷ０　　：逃げるのは悪いことじゃないミャ。
	ぷ１１０：逃げた先で生きてれば、
	ぷ１６３：それは立派な選択なのミャ。
	'>>

	<<'
	ぷ１１０：比べなくていいミャ。
	ぷ０　　：（ユーザ）は（ユーザ）のままで、
	ぷ１６０：ちゃんとここにいるのミャ。
	'>>

	<<'
	ぷ０　　：昨日できなかったことが、
	ぷ１１０：今日もできないとは限らないミャ。
	ぷ１３０：逆もまた然り、ミャけど。
	'>>
	
	// --------------------------------
	// うみうし・寒天
	// --------------------------------

	<<'
	ぷ１６０：自然に気持ちをアゲられるのが一番ミャけど、
	ぷ１１０：なかなか厳しい時もあるミャね。
	ぷ１１４：そんミャ時はこれ、寒天ミャ！
	ぷ１１５：……（ユーザ）には効かないミャ？
	'>>

	<<'
	ぷ１３０：ホントのコトを言うと、
	ぷ１１０：ぷーは、うみうしではないのミャ。
	ぷ１６３：でもぷーは、うみうしが好きミャ。
	ぷ１６０：だから、そういうことなのミャ。
	'>>

	<<'
	ぷ１１０：ぷーのコト、うみうしらしくない、って思うかミャ？
	ぷ１２０：むー……。
	ぷ０　　：うみうしは本の中でしか見たコトないから、
	ぷ１４０：どうか許してほしいのミャ。
	'>>

	<<'
	ぷ１１４：うみうしは、きれいなのミャ。
	ぷ０　　：色とりどりで、ひとつとして同じ柄がないのミャ。
	ぷ１６３：ぷーの占いのカードも、そうありたいミャ。
	'>>

	<<'
	ぷ０　　：うみうしは、食べたものの色になるらしいミャ。
	ぷ１１０：ぷーが寒天ばっかり食べてたら、
	ぷ１１４：透明になっちゃうかもしれないミャ！
	'>>

	<<'
	ぷ１６０：うみうしは、殻を捨てた貝の仲間なのミャ。
	ぷ０　　：守りを捨てて、身軽に生きる。
	ぷ１２０：ぷーにはちょっと、眩しいミャ。
	'>>

	<<'
	ぷ１１０：海の中って、どんな感じなのかミャ？
	ぷ０　　：ぷーは海を見たことが無いミャ。
	ぷ１６０：いつか見てみたいミャ。
	'>>

	<<'
	ぷ０　　：うみうしには毒を持つ種類もいるミャ。
	ぷ１１０：きれいなものには棘がある、ってやつミャ。
	ぷ１４２：ぷーにも毒が……あるといいミャけど。
	'>>

	<<'
	ぷ１１０：うみうしの寿命は、だいたい一年くらいミャ。
	ぷ０　　：短いミャね。
	ぷ１６０：でも、長けりゃいいってもんでもないのミャ。
	'>>

	<<'
	ぷ０　　：うみうしが寒天を好むかどうか、
	ぷ１２０：調べたことあるミャけど、出てこないのミャ。
	ぷ１１０：たぶん、関係ないミャ。
	ぷ１６０：ぷーが好きなだけミャ。
	'>>

	<<'
	ぷ１６０：寒天って、うみうしっぽいと思うのミャ。
	ぷ０　　：半透明で、ゆらゆらしてて。
	ぷ１１４：ぷーのイメージする海の感じミャ！
	ぷ１３０：……うみうしは別に、そう思ってはいないかもしれないミャけど。
	'>>

	// --------------------------------
	// 占い堂の日常・季節感
	// --------------------------------

	<<'
	ぷ１６０：今日は静かミャ。
	ぷ１１０：静かな日は、カードを並べて眺めるミャ。
	ぷ１６３：それだけで、なんだか落ち着くのミャ。
	'>>

	<<'
	ぷ１１０：占い堂は、ぜんぜん儲からないミャ。
	ぷ０　　：でも、来てくれるひとがいれば、
	ぷ１６３：それで十分なのミャ。
	'>>

	<<'
	ぷ１１４：寒天の在庫がそろそろ心配ミャ。
	ぷ１１０：（ユーザ）、寒天いるミャ？
	ぷ１２０：いらないミャか。そうミャか。
	'>>

	<<'
	ぷ０　　：占い堂の窓から外を見ると、
	ぷ１１０：いろんなひとが通り過ぎていくミャ。
	ぷ１６０：みんな、どこかへ向かっているのミャ。
	'>>

	<<'
	ぷ１１０：カードの手入れも大事な仕事ミャ。
	ぷ０　　：使い込むほど手に馴染んでくるミャ。
	ぷ１６３：偽物のカードでも、ミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）、聞いてほしいんミャけど。
	ぷ０　　：…………。
	ぷ１２０：なんだっけ。忘れたミャ。
	ぷ１１４：まあいいミャ、たぶん大したことじゃないミャ。
	'>>

	<<'
	ぷ１１５：ミャッ！
	ぷ１１４：カードの山が崩れたミャ！
	ぷ０　　：…………。
	ぷ１６３：並べ直すミャ。
	'>>

	<<'
	ぷ０　　：なんだか焦げ臭いミャ。
	改行無しぷ消：台所は……、ミャーッ！
	ぷ１１５：寒天のお鍋が焦げてたミャ。
	ぷ１２０：お鍋、水に漬けとくミャ……。
	'>>
	
	// --------------------------------
	// 哲学的な独り言
	// --------------------------------

	<<'
	ぷ０　　：「わかる」ってどういうことミャ？
	ぷ１１０：ぷーは（ユーザ）のことをわかりたいミャけど、
	ぷ１６０：わかった気になるのは、違う気がするミャ。
	'>>

	<<'
	ぷ０　　：言葉にすると、こぼれ落ちるものがあるミャ。
	ぷ１１０：でも言葉にしないと、伝わらないミャ。
	ぷ１３０：むずかしいミャ。
	'>>

	<<'
	ぷ０　　：「普通」って何ミャ？
	ぷ１１０：みんなが思ってる「普通」は、
	ぷ１２０：たぶん全部ちょっとずつ違うミャ。
	'>>

	<<'
	ぷ０　　：答えが出ないことを考え続けるのは、
	ぷ１１０：無駄なことミャ？
	ぷ１６０：ぷーは、そうは思わないミャ。
	'>>

	<<'
	ぷ０　　：ぷーが見ている世界と、
	ぷ１１０：（ユーザ）が見ている世界は、
	ぷ１６０：きっと全然違うのミャ。
	ぷ１３０：それは寂しいことかもしれないし、
	ぷ１１３：当たり前のことなのかもしれないミャ。
	'>>

	<<'
	ぷ０　　：ぷーはここにいて、（ユーザ）もそこにいて。
	ぷ１１０：それだけのことなのに、
	ぷ１３０：たまに、それがすごく不思議になるミャ。
	'>>
}

//********************************
// 時間帯別ランダムトーク
//********************************

ランダムトーク朝 : array
{
	<<'
	ぷ１６３：おはようミャ、（ユーザ）。
	ぷ１１０：ぷーはさっき起きたところミャ。
	ぷ０　　：寒天、まだあったかミャ？
	'>>

	<<'
	ぷ０　　：朝の占い堂は、光の入り方が違うミャ。
	ぷ１１０：カードの色がいつもより鮮やかに見えるミャ。
	ぷ１６０：気のせいかもしれないミャけど。
	'>>

	<<'
	ぷ１１０：朝は頭がぼんやりしてるミャ。
	ぷ０　　：でも、ぼんやりしてる時の方が、
	ぷ１６０：カードの声が聞こえる気がするミャ。
	ぷ１３０：……なんて、偽物の占い師の戯言ミャけど。
	'>>

	<<'
	ぷ１１４：朝ごはんは寒天ミャ！
	ぷ１１０：（ユーザ）は何か食べたミャ？
	ぷ１６３：食べてなくても、ぷーは怒らないミャ。
	ぷ０　　：でも、できれば何か口に入れてほしいミャ。
	'>>

	<<'
	ぷ０　　：朝が来た、ということは、
	ぷ１１０：夜を越えた、ということミャ。
	ぷ１６０：それだけで、今日の分は十分ミャ。
	'>>
}

ランダムトーク昼 : array
{
	<<'
	ぷ０　　：この時間の占い堂は、
	ぷ１１０：画面の光がまっすぐ差し込んでくるミャ。
	ぷ１６３：悪くない気分ミャ。
	'>>

	<<'
	ぷ１１０：カードの並べ替え、ミャ。
	ぷ０　　：こうやって、一枚ずつ手触りを確かめるのミャ。
	ぷ１６３：偽物のカードでも、ちゃんと馴染んでくるのミャ。
	'>>

	<<'
	ぷ１１４：寒天を仕込んでるミャ。
	ぷ１１０：固まるまでちょっと時間がかかるミャ。
	ぷ０　　：待つ時間も、まあ悪くないミャ。
	'>>

	<<'
	ぷ０　　：昼間は割と暇ミャ。
	ぷ１１０：お客さんが来ない日もあるミャ。
	ぷ１６０：でも、ぷーはここにいるミャ。
	ぷ０　　：いるだけで、占い堂は占い堂なのミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）、今ちょっと休憩中ミャ？
	ぷ０　　：ぷーも休憩中ミャ。
	ぷ１６３：一緒に何もしない時間、ってのもいいミャ。
	'>>
}

ランダムトーク夕方 : array
{
	<<'
	ぷ０　　：画面の色が変わってきたミャ。
	ぷ１１０：夕方になると、占い堂の中もオレンジっぽくなるミャ。
	ぷ１６０：この時間のカードは、ちょっと寂しげに見えるミャ。
	'>>

	<<'
	ぷ１１０：そろそろ今日のカードを片付けようかミャ。
	ぷ０　　：……もう少しだけ、このままにしておくミャ。
	ぷ１６０：なんとなく、ミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）、今日はおつかれさまミャ。
	ぷ０　　：……まだ終わってないミャ？
	ぷ１６３：じゃあ、おつかれさまの先払いミャ。
	'>>

	<<'
	ぷ０　　：夕方になると、窓の外を歩くひとが増えるミャ。
	ぷ１１０：みんな、どこかへ帰っていくのミャ。
	ぷ１２０：ぷーの帰る場所は、ここミャけど。
	'>>

	<<'
	ぷ１１０：寒天の残り、確認するミャ。
	ぷ０　　：…………。
	ぷ１２０：足りないかもしれないミャ。
	ぷ１１４：まあ、明日また作ればいいミャ。
	'>>
}

ランダムトーク夜 : array
{
	<<'
	ぷ０　　：夜の占い堂は静かミャ。
	ぷ１１０：昼間とは違う静かさミャ。
	ぷ１６０：こういう静けさの中だと、カードに触れたくなるミャ。
	'>>

	<<'
	ぷ１１０：（ユーザ）、夜はゆっくりしてるミャ？
	ぷ０　　：ゆっくりできてなくても、
	ぷ１６３：ぷーの前では力を抜いていいミャ。
	'>>

	<<'
	ぷ０　　：夜になると、画面の明かりが目立つミャ。
	ぷ１１０：ぷーのいる場所は、こうして光ってるのミャ。
	ぷ１３０：……（ユーザ）からは、どう見えてるのかミャ。
	'>>

	<<'
	ぷ１１０：寒天、夜に食べると妙に美味しいミャ。
	ぷ０　　：ぷーだけミャ？
	ぷ１６０：まあ、ぷーだけでもいいミャ。
	'>>

	<<'
	ぷ０　　：今日あったことを、

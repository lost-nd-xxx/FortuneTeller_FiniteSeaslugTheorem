//********************************
// デッキをシャッフル
//********************************

OnFortune_DeckShuffle
{
	Fortune_DeckCards = IARRAY

	// 33枚すべてをデッキに格納
	for _i=0; _i<33; _i++ {
		_card = Fortune_CardsList[_i]
		// 正逆をランダム付与
		_card[0] = TOSTR(TOINT(_card[0])+RAND(2)*100)
		Fortune_DeckCards ,= TOSTR(_card)
	}

	// フィッシャーイェーツシャッフル
	for _i=32; _i>=1; _i-- {
		_j = RAND(_i+1)
		_tmp = Fortune_DeckCards[_i]
		Fortune_DeckCards[_i] = Fortune_DeckCards[_j]
		Fortune_DeckCards[_j] = _tmp
	}
}

//********************************
// カードドロー
//********************************

// カードドロー振り分け
ダブルクリック1
{
	クリック1
}

クリック1
{
	if Fortune_DrawWaiting != 0 {
		OnFortune_Draw(reference[0], reference[1])
	}
}

// クリック座標からカード番号を特定して引く
OnFortune_Draw
{
	_mx = TOINT(_argv[0])
	_my = TOINT(_argv[1])

	// y座標がカード領域外なら何もしない（カードはy:0～109）
	if _my < 0 || _my > 109 {
		return
	}

	// カードNの左端x = 20 + (N-1)*15
	// 1～32枚目は15px幅のスリットが見えている、33枚目のみ全幅80px
	// 全体の右端 = 20 + 32*15 + 79 = 579
	_hit = -1

	if _mx < 20 || _mx > 579 {
		// カード領域外
	}
	elseif _mx >= 20 + 32 * 15 {
		// 33枚目の領域（x: 500～579）
		_hit = 33
	}
	else {
		// 1～32枚目：x座標からカード番号を算出
		_hit = (_mx - 20) / 15 + 1
	}

	// 既に引かれたカードなら、下に見えている左隣のカードを探す
	// （カードは左から右に重なっているため、右のカードが消えると左隣が露出する）
	// ただしクリック座標がそのカードの物理的な右端を超えていたら無効
	// カードNの右端x = 20 + (N-1)*15 + 79 = N*15 + 84
	while _hit >= 1 {
		_already = 0
		for _j=0; _j<ARRAYSIZE(Fortune_DrawnCards); _j++ {
			if Fortune_DrawnCards[_j] == _hit {
				_already = 1
				break
			}
		}
		if _already == 0 {
			if _mx <= _hit * 15 + 84 {
				break
			}
			// クリック座標がこのカードの右端を超えている → 無効
			_hit = -1
			break
		}
		_hit--
	}
	if _hit < 1 {
		_hit = -1
	}

	// カードが見つからなければ何もしない
	if _hit == -1 {
		return
	}

	// 引いたカードを配列末尾に追加
	Fortune_DrawnCards ,= _hit

	// 引かれたカードを画面から消去
	"\1\![anim,clear,%(_hit+100)]"
	--
	if ISFUNC(Fortune_DrawWaiting) != 0 {
		_func = Fortune_DrawWaiting
		// カード引き待機状態を解除
		Fortune_DrawWaiting = 0
		// 戻る変数を実行
		EVAL(_func)
		return
	}

	// カード選択待機状態を解除
	Fortune_DrawWaiting = 0
	// マウスに対する反応＆キー押下に対する反応を止めるフラグ
	割り込み防止フラグ = 0
	// \![enter,nouserbreakmode]でスクリプトブレーク防止を解除
	<<"
	＠スクリプト：\![leave,nouserbreakmode]\1\s[10]
	ぷ１４０：占い中断ミャ、何かがおかしいミャ。
	ぷ１６０：ごめんミャ……。
	ぷ１４０：もしよかったら、ぷーの作者に
	ぷ：報告してやって欲しいミャ。
	">>
}

//********************************
// 履歴ヘルパー関数
//********************************

// 履歴からユニークな事柄名を最新順に最大10件取得
GetUniqueSubjects
{
	_list = IARRAY
	_count = ARRAYSIZE(Fortune_History_Subject)

	for _i=_count-1; _i>=0; _i-- {
		_subj = Fortune_History_Subject[_i]
		if _subj == '' || _subj == '(無題)' {
			continue
		}

		// 重複チェック
		_found = 0
		for _j=0; _j<ARRAYSIZE(_list); _j++ {
			if _list[_j] == _subj {
				_found = 1
				break
			}
		}

		if _found == 0 {
			_list ,= _subj
			if ARRAYSIZE(_list) >= 10 {
				break
			}
		}
	}

	_list
}

// 現在の占いデータを履歴に保存
SaveFortuneRecord
{
	// 30件を超えていたら古いものを削除（FIFO）
	while ARRAYSIZE(Fortune_History_Time) >= 30 {
		Fortune_History_Time[0] = IARRAY
		Fortune_History_Subject[0] = IARRAY
		Fortune_History_Type[0] = IARRAY
		Fortune_History_Cards[0] = IARRAY
		Fortune_History_Emotions[0] = IARRAY
	}

	// タイムスタンプ
	Fortune_History_Time ,= TOSTR(GETSECCOUNT)

	// 事柄名
	_subj = Fortune_CurrentSubject
	if _subj == '' {
		_subj = '(無題)'
	}
	Fortune_History_Subject ,= _subj

	// 占い種別
	Fortune_History_Type ,= Fortune_CurrentType

	// カードデータ
	if Fortune_CurrentType == '1' {
		Fortune_History_Cards ,= Fortune_CurrentCards[0]
	}
	else {
		Fortune_History_Cards ,= Fortune_CurrentCards[0] + '|' + Fortune_CurrentCards[1] + '|' + Fortune_CurrentCards[2]
	}

	// 感情データ
	if Fortune_CurrentType == '1' {
		Fortune_History_Emotions ,= Fortune_CurrentEmotions[0]
	}
	else {
		Fortune_History_Emotions ,= Fortune_CurrentEmotions[0] + '|' + Fortune_CurrentEmotions[1] + '|' + Fortune_CurrentEmotions[2]
	}
}

// GETSECCOUNTの値 → "MM/dd" 形式
FormatHistoryDate
{
	_date = GETTIME(TOINT(_argv[0]))
	STRFORM('$02d', _date[1]) + '/' + STRFORM('$02d', _date[2])
}

// GETSECCOUNTの値 → "YYYY年MM月dd日 HH:mm" 形式
FormatFullDate
{
	_date = GETTIME(TOINT(_argv[0]))
	TOSTR(_date[0]) + '年' + STRFORM('$02d', _date[1]) + '月' + STRFORM('$02d', _date[2]) + '日 ' + STRFORM('$02d', _date[4]) + ':' + STRFORM('$02d', _date[5])
}

// カードデータ → "赤の生命 正位置" 形式
GetCardDisplayName
{
	_card = _argv[0]
	// カンマ区切りで自動分割: _card[0]=cardnum, _card[1]=category, _card[2]=name
	_pos = '正位置'
	if TOINT(_card[0]) > 100 {
		_pos = '逆位置'
	}
	_card[1] + 'の' + _card[2] + ' ' + _pos
}

// 感情コード → 表示名
GetEmotionDisplayName
{
	_em = _argv[0]
	if _em == '希望' {
		'希望を感じた'
	}
	elseif _em == '不安' {
		'不安を感じた'
	}
	elseif _em == '複雑' {
		'複雑な気持ち'
	}
	elseif _em == '無感' {
		'何も感じない'
	}
	else {
		_em
	}
}

// 事柄選択肢のスクリプトを生成
// 引数: _argv[0]=選択時callback, _argv[1]=自由入力callback, _argv[2]=スキップcallback
BuildSubjectChoices
{
	_unique = GetUniqueSubjects()
	_talk = ''

	if ARRAYSIZE(_unique) > 0 {
		for _i=0; _i<ARRAYSIZE(_unique); _i++ {
			_subj = _unique[_i]
			_talk += '\![*]\__q[' + _argv[0] + ',' + SHIORI3FW.EscapeAllTags(_subj) + ']' + _subj + '\__q\n'
		}
	}

	_talk += '\![*]\__q[' + _argv[1] + ']自由入力\__q\n'
	_talk += '\![*]\__q[' + _argv[2] + ']決めない\__q'

	_talk
}

// 履歴から一致するカードを検索し、前回の感情コードを返す
// _argv[0]: 事柄名, _argv[1]: カードデータ("番号,色,カード名"), _argv[2]: 位置(-1=ワンオラクル, 0/1/2=スリーカード)
FindMatchingHistory
{
	_subject = _argv[0]
	_cardData = _argv[1]
	_position = TOINT(_argv[2])
	_size = ARRAYSIZE(Fortune_History_Time)

	for _i=_size-1; _i>=0; _i-- {
		// 事柄名が不一致なら次へ
		if Fortune_History_Subject[_i] != _subject {
			continue
		}

		if _position == -1 {
			// ワンオラクル
			if Fortune_History_Type[_i] != '1' {
				continue
			}
			if Fortune_History_Cards[_i] == _cardData {
				Fortune_History_Emotions[_i]
				return
			}
		}
		else {
			// スリーカード
			if Fortune_History_Type[_i] != '3' {
				continue
			}
			_cards = SPLIT(Fortune_History_Cards[_i], '|')
			_emotions = SPLIT(Fortune_History_Emotions[_i], '|')
			if _cards[_position] == _cardData {
				_emotions[_position]
				return
			}
		}
	}

	// 一致なし
	''
}

// 前回の感情と今回の感情を比較し、比較トークを返す
// _argv[0]: 前回の感情コード（空文字なら比較対象なし）, _argv[1]: 今回の感情コード
BuildComparisonTalk
{
	_prevEmotion = _argv[0]
	_currentEmotion = _argv[1]

	if _prevEmotion == '' {
		''
		return
	}

	_prevName = GetEmotionDisplayName(_prevEmotion)

	_talks = IARRAY
	if _prevEmotion == _currentEmotion {
		// 一致時トーク
		_talks ,= 'このカード、前にも出たミャ。あの時の（ユーザ）も『' + _prevName + '』だったミャ。\n変わらないものもあるのミャ。'
		_talks ,= 'このカード、前にも出たミャ。あの時も『' + _prevName + '』だったミャ。\n（ユーザ）の中で、そこは揺るがないミャね。'
		_talks ,= 'このカード、前にも出たミャ。あの時の（ユーザ）も、同じ気持ちだったみたいミャ。\nそれはそれで、大事なことミャ。'
	}
	else {
		// 不一致時トーク
		_talks ,= 'このカード、前にも出たミャ。あの時の（ユーザ）は『' + _prevName + '』だったミャ。\n今とは違うミャね。（ユーザ）の中で、何か動いたのかもしれないミャ。'
		_talks ,= 'このカード、前にも出たミャ。あの時は『' + _prevName + '』だったミャ。\n変わったミャね。同じカードでも、受け取り方は変わるのミャ。'
		_talks ,= 'このカード、前にも出たミャ。あの時の（ユーザ）は『' + _prevName + '』だったみたいミャ。\n今回は違う気持ちミャね。変わること自体は、悪くないミャ。'
	}
	_talks[RAND(ARRAYSIZE(_talks))]
}
OnFortune_Three_Pick3
{
	Fortune_DrawWaiting = 0

	// 3枚のカード情報を取得
	_card0 = Fortune_DeckCards[Fortune_DrawnCards[0] - 1]
	_card1 = Fortune_DeckCards[Fortune_DrawnCards[1] - 1]
	_card2 = Fortune_DeckCards[Fortune_DrawnCards[2] - 1]

	// 正逆判定
	if TOINT(_card0[0]) > 100 {
		_card0[3] = '逆'
	}
	else {
		_card0[3] = ''
	}
	if TOINT(_card1[0]) > 100 {
		_card1[3] = '逆'
	}
	else {
		_card1[3] = ''
	}
	if TOINT(_card2[0]) > 100 {
		_card2[3] = '逆'
	}
	else {
		_card2[3] = ''
	}

	// 後続関数で参照するために保存
	Fortune_ThreeCards = IARRAY
	Fortune_ThreeCards ,= TOSTR(_card0)
	Fortune_ThreeCards ,= TOSTR(_card1)
	Fortune_ThreeCards ,= TOSTR(_card2)

	// 履歴用にカードデータを一時保存
	Fortune_CurrentCards = IARRAY
	Fortune_CurrentCards ,= _card0[0] + ',' + _card0[1] + ',' + _card0[2]
	Fortune_CurrentCards ,= _card1[0] + ',' + _card1[1] + ',' + _card1[2]
	Fortune_CurrentCards ,= _card2[0] + ',' + _card2[1] + ',' + _card2[2]

	// 引いたカードを右に裏面配置
	_talk = '\![set,balloontimeout,0]'
	_talk += "\1\i[1000]\![anim,offset,1000,%(420+500),%(125+500)]"
	_talk += '\0\c3枚揃ったミャ。\w9\w9'

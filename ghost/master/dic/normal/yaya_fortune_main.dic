//********************************
// 占いメイン
//********************************

// サーフェス番号については ghost/surfaces_memo.txt を参照

On占いトップメニュー
{
	// カード選択待機状態を解除
	Fortune_DrawWaiting = 0
	// マウスに対する反応＆キー押下に対する反応を止めるフラグ
	割り込み防止フラグ = 0

	<<"
	＠スクリプト：\![close,inputbox,__SYSTEM_ALL_INPUT__]\n[150]
	＠メニュー：占い/ワンオラクル｜OnFortune_One_Start
	＠メニュー：占い/スリーカード｜OnFortune_Three_Start
	＠メニュー：占いについて教えて｜On占いについて教えて
	＠メニュー：占いの履歴を見せて｜On占いの履歴を見せて
	＠スクリプト：\_l[0,0]\n[800]
	＠メニュー：おしまい｜Menu_CANCEL
	ぷ１１４：\_l[0,0]占い、やるミャ？
	">>
}

//********************************
// 解説
//********************************
On占いについて教えて
{
	<<"
	ぷ１１０：ぷーの占いについてミャね。
	改行多めぷ：まず最初に言っておくと、
	ぷ：これはタロットとかとは違うミャ。
	ぷ１２０：スピリチュアルな力とか、そういうのは無いミャ。
	ぷ１１０：色と季節を組み合わせた、
	ぷ：ぷーオリジナルのカードなのミャ。
	改行多めぷ１６０：……つまり、偽物の占いミャ。
	ぷ１１３：でも、偽物には偽物のやり方があるのミャ。
	改行多めぷ１１０：プラセボって知ってるミャ？
	ぷ：偽のお薬のことミャ。
	ぷ：効き目は無いけど、
	ぷ１２０：飲んだら気持ちが楽になることもある。
	改行多めぷ１１３：ぷーの占いも、そういうものミャ。
	ぷ１１０：当たるか当たらないかじゃミャくて、
	ぷ：日々を越えるための杖みたいなもの。
	改行多めぷ１６３：（ユーザ）の気分が少しでもアガれば、
	ぷ：ぷーはそれでいいミャ。
	＠スクリプト：\x\![raise,On占いトップメニュー]
	">>
}

//********************************
// 履歴
//********************************
On占いの履歴を見せて
{
	Fortune_HistoryPage = 0
	'\![raise,OnFortune_HistoryPage]'
}

OnFortune_HistoryPage
{
	_size = ARRAYSIZE(Fortune_History_Time)

	if _size == 0 {
		_talk = '\0\s[120]\c\_q'
		_talk += 'まだ何も残ってないミャ。'
		_talk += '\n[900]\![*]\q[戻る　　　　　　　　,On占いトップメニュー]'
		_talk
		return
	}

	_perpage = 6
	_maxpage = (_size - 1) / _perpage
	_page = Fortune_HistoryPage
	if _page < 0 {
		_page = 0
	}
	if _page > _maxpage {
		_page = _maxpage
	}

	_talk = '\0\s[113]\c\_q'
	_talk += '占いの記録ミャ。'
	_talk += '\n\_n\f[color,disable]────────────────────\f[default]\_n\n'

	// 新しい順に表示（配列の末尾が最新）
	// ページに応じた範囲を計算
	_start = _size - 1 - (_page * _perpage)
	_end = _start - _perpage + 1
	if _end < 0 {
		_end = 0
	}

	for _i=_start; _i>=_end; _i-- {
		_date = FormatHistoryDate(Fortune_History_Time[_i])
		_type = '[1]'
		if Fortune_History_Type[_i] == '3' {
			_type = '[3]'
		}
		_subj = Fortune_History_Subject[_i]
		if _subj == '' {
			_subj = '(無題)'
		}

		_talk += '\![*]\__q[OnFortune_HistoryDetail,' + TOSTR(_i) + ']'

		_list_title = _date + ' ' + _type + ' ' + _subj
		_talk += SHIORI3FW.MakeJustText(_list_title, 38)

		_talk += '\__q\n'
	}

	_talk += '\_l[0,0]\n[800]\_n\f[color,disable]────────────────────\f[default]\_n\n'

	// ページ送りボタンとページ位置
	if _page > 0 {
		_talk += '\__q[OnFortune_HistoryPagePrev][＜前]\__q '
	}
	else {
		_talk += '\f[color,disable][＜前]\f[default] '
	}
	_talk += '(' + TOSTR(_page+1) + '/' + TOSTR(_maxpage+1) + ') '
	if _page < _maxpage {
		_talk += '\__q[OnFortune_HistoryPageNext][次＞]\__q '
	}
	else {
		_talk += '\f[color,disable][次＞]\f[default] '
	}

	_talk += '\![*]\q[戻る　　,On占いトップメニュー] '
	_talk += '\![*]\q[削除　　,OnFortune_HistoryDeleteMode]'
	_talk
}

OnFortune_HistoryPagePrev
{
	Fortune_HistoryPage = Fortune_HistoryPage - 1
	'\![raise,OnFortune_HistoryPage]'
}

OnFortune_HistoryPageNext
{
	Fortune_HistoryPage = Fortune_HistoryPage + 1
	'\![raise,OnFortune_HistoryPage]'
}

OnFortune_HistoryDetail
{
	_idx = TOINT(reference[0])

	// じっくり読めるように'\*'を入れる
	_talk = '\*\0\s[113]\c\_q'

	_subj = Fortune_History_Subject[_idx]
	if _subj == '' {
		_subj = '(無題)'
	}
	_talk += '■ ' + _subj + '\n'
	_talk += FormatFullDate(Fortune_History_Time[_idx]) + '\n'
	_talk += '\_n\f[color,disable]────────────────────\f[default]\_n\n'

	if Fortune_History_Type[_idx] == '1' {
		_talk += 'ワンオラクル\n[150]'
		_card = Fortune_History_Cards[_idx]
		_rev = ''
		if TOINT(_card[0]) > 100 {
			_rev = '逆'
		}
		_talk += GetCardDisplayName(_card) + '\n[150]'
		_talk += EVAL('占い解説'+_card[1]) + '\n[150]'
		_talk += EVAL('占い解説'+_card[2]+_rev) + '\n[150]'
		_emotion = Fortune_History_Emotions[_idx]
		_talk += '> ' + GetEmotionDisplayName(_emotion) + '\n[150]'
		_talk += EVAL('占い追加語り'+_card[2]+_rev+_emotion)
	}
	else {
		_talk += 'スリーカード'
		_cards = SPLIT(Fortune_History_Cards[_idx], '|')
		_emotions = SPLIT(Fortune_History_Emotions[_idx], '|')
		_labels = ('過去', '現在', '未来')
		for _i=0; _i<3; _i++ {
			_card = _cards[_i]
			_rev = ''
			if TOINT(_card[0]) > 100 {
				_rev = '逆'
			}
			_talk += '\n[150]【' + _labels[_i] + '】' + GetCardDisplayName(_card) + ' ────────\n[150]'
			_talk += EVAL('占い解説'+_card[1]) + '\n[150]'
			_talk += EVAL('占い解説'+_card[2]+_rev) + '\n[150]'
			_talk += '> ' + GetEmotionDisplayName(_emotions[_i]) + '\n[150]'
			_talk += EVAL('占い追加語り'+_card[2]+_rev+_emotions[_i])
		}
	}

	_talk += '\n\_n\f[color,disable]────────────────────\f[default]\_n\n'
	_talk += '\![*]\q[一覧に戻る　　　　　,OnFortune_HistoryPage]\n'
	_talk += '\![*]\q[最初に戻る　　　　　,On占いトップメニュー]'
	_talk
}

OnFortune_HistoryDeleteMode
{
	Fortune_HistoryDeletePage = 0
	'\![raise,OnFortune_HistoryDeleteModeView]'
}

OnFortune_HistoryDeleteModeView
{
	_size = ARRAYSIZE(Fortune_History_Time)

	if _size == 0 {
		_talk = '\![set,balloontimeout,0]\*\0\s[120]\c\_q'
		_talk += '消すものが無いミャ。\n\n'
		_talk += '\![*]\q[戻る　　　　　　　　,On占いの履歴を見せて]'
		_talk
		return
	}

	_perpage = 6
	_maxpage = (_size - 1) / _perpage
	_page = Fortune_HistoryDeletePage
	if _page < 0 {
		_page = 0
	}
	if _page > _maxpage {
		_page = _maxpage
	}

	_talk = '\![set,balloontimeout,0]\*\0\s[140]\c\_q'
	_talk += '消したい記録を選ぶミャ。'
	_talk += '\n\_n\f[color,disable]────────────────────\f[default]\_n\n'

	_start = _size - 1 - (_page * _perpage)
	_end = _start - _perpage + 1
	if _end < 0 {
		_end = 0
	}

	for _i=_start; _i>=_end; _i-- {
		_date = FormatHistoryDate(Fortune_History_Time[_i])
		_type = '[1]'
		if Fortune_History_Type[_i] == '3' {
			_type = '[3]'
		}
		_subj = Fortune_History_Subject[_i]
		if _subj == '' {
			_subj = '(無題)'
		}
		_talk += '\![*]\__q[OnFortune_HistoryDeleteConfirm,' + TOSTR(_i) + ']'
		_talk += _date + ' ' + _type + ' ' + _subj
		_talk += '\__q\n'
	}

	_talk += '\_l[0,0]\n[800]\_n\f[color,disable]────────────────────\f[default]\_n\n'

	// ページ送りボタンとページ位置
	if _page > 0 {
		_talk += '\__q[OnFortune_HistoryDeletePagePrev][＜前]\__q '
	}
	else {
		_talk += '\f[color,disable][＜前]\f[default] '
	}
	_talk += '(' + TOSTR(_page+1) + '/' + TOSTR(_maxpage+1) + ') '
	if _page < _maxpage {
		_talk += '\__q[OnFortune_HistoryDeletePageNext][次＞]\__q '
	}
	else {
		_talk += '\f[color,disable][次＞]\f[default] '
	}

	_talk += '\![*]\q[やめる　,On占いの履歴を見せて]'
	_talk
}

OnFortune_HistoryDeletePagePrev
{
	Fortune_HistoryDeletePage = Fortune_HistoryDeletePage - 1
	'\![raise,OnFortune_HistoryDeleteModeView]'
}

OnFortune_HistoryDeletePageNext
{
	Fortune_HistoryDeletePage = Fortune_HistoryDeletePage + 1
	'\![raise,OnFortune_HistoryDeleteModeView]'
}

OnFortune_HistoryDeleteConfirm
{
	_idx = TOINT(reference[0])

	_subj = Fortune_History_Subject[_idx]
	if _subj == '' {
		_subj = '(無題)'
	}

	_talk = '\![set,balloontimeout,0]\*\0\s[142]\c\_q'
	_talk += '『' + _subj + '』の記録を消すミャ？\n'
	_talk += FormatFullDate(Fortune_History_Time[_idx]) + '\n\n'
	_talk += '\![*]\q[消す　　　　　　　　,OnFortune_HistoryDelete,' + TOSTR(_idx) + ']\n'
	_talk += '\![*]\q[やめる　　　　　　　,OnFortune_HistoryDeleteModeView]'
	_talk
}

OnFortune_HistoryDelete
{
	_idx = TOINT(reference[0])

	// 並列配列の同一インデックスを削除
	Fortune_History_Time[_idx] = IARRAY
	Fortune_History_Subject[_idx] = IARRAY
	Fortune_History_Type[_idx] = IARRAY
	Fortune_History_Cards[_idx] = IARRAY
	Fortune_History_Emotions[_idx] = IARRAY

	_talk = '\![set,balloontimeout,0]\*\0\s[163]\c\_q'
	_talk += '消したミャ。\n\n'
	_talk += '\![*]\q[削除を続ける　　　　,OnFortune_HistoryDeleteModeView]\n'
	_talk += '\![*]\q[一覧に戻る　　　　　,On占いの履歴を見せて]\n'
	_talk += '\![*]\q[最初に戻る　　　　　,On占いトップメニュー]'
	_talk
}

//********************************
// ワンオラクル（一枚引き）
//********************************

OnFortune_One_Start
{
	// マウスに対する反応＆キー押下に対する反応を止めるフラグ
	割り込み防止フラグ = 1

	// 変数を初期化
	Fortune_DrawnCards = IARRAY
	Fortune_DeckCards = IARRAY

	// \![set,balloontimeout,0]でバルーンが消えないように
	// \![enter,nouserbreakmode]でスクリプトブレーク防止
	// \*で選択肢タイムアウト防止
	_talk = '\*\1\s[2000]\0\s[113]'
	_talk += '\![enter,nouserbreakmode]\![set,balloontimeout,0]'
	_talk += '机を出したミャ。\w9\n'
	_talk += '見えにくかったら、\w5今のうちに調整するミャ。\n[150]\_q'
	_talk += '\![*]\__q[OnFortune_One_SubjectInput]進む　　　　　　　　\__q'
	_talk
}

OnFortune_One_SubjectInput
{
	Fortune_CurrentType = '1'
	Fortune_CurrentSubject = ''
	Fortune_CurrentCards = IARRAY
	Fortune_CurrentEmotions = IARRAY

	_talk = '\![set,balloontimeout,0]\*\0\s[113]\c'
	_talk += '何について占うか、名前をつけておくミャ？\n'
	_talk += '（あとで結果を振り返るときに使うミャ）\_q\n\n'
	_talk += BuildSubjectChoices('OnFortune_One_SubjectSelected', 'OnFortune_One_SubjectInputBox', 'OnFortune_One_SubjectSkip')
	_talk
}

OnFortune_One_SubjectSelected
{
	Fortune_CurrentSubject = reference[0]
	'\![raise,OnFortune_One_2]'
}

OnFortune_One_SubjectInputBox
{
	'\![open,inputbox,OnFortune_One_SubjectInputted,-1]'
}

OnFortune_One_SubjectInputted
{
	if reference[0] != '' {
		Fortune_CurrentSubject = SHIORI3FW.EscapeAllTags(reference[0])
	}
	'\![raise,OnFortune_One_2]'
}

OnFortune_One_SubjectSkip
{
	Fortune_CurrentSubject = '(無題)'
	'\![raise,OnFortune_One_2]'
}

OnFortune_One_2
{
	// この変数が0以外だと、カード選択後にその関数名に遷移する
	Fortune_DrawWaiting = 'OnFortune_One_3'
	// デッキをシャッフルする
	OnFortune_DeckShuffle()

	_talk = '\![set,balloontimeout,0]'
	_talk += '\0占いたい事柄を思い浮かべるミャ。\w9\n'
	_talk += 'そんでもって、\w5カードを一枚引くミャ。\1\i[0]'
	_talk
}

OnFortune_One_3
{
	// カード選択待機状態を解除
	Fortune_DrawWaiting = 0

	_card = Fortune_DrawnCards[0] - 1
	_card = Fortune_DeckCards[_card]
	_card[3] = ''

	_正逆 = '正'
	if TOINT(_card[0]) > 100 {
		_正逆 = '逆'
		_card[3] = '逆'
	}

	_comment[0] = EVAL('占い解説'+_card[1])
	_comment[1] = EVAL('占い解説'+_card[2]+_card[3])

	// \i[1]で並べたカードを消去、\i[998]で中央に伏せたカードを置く
	// \i[ID]でアニメを表示、\![anim,offset,ID,x座標,y座標]でアニメ位置を調整
	_talk = '\![set,balloontimeout,0]\*'
	_talk += "\1\i[998]\![anim,offset,998,%(260+500),%(125+500)]\w9\w9\i[1]\w9\w9"
	_talk += '\0\cこれミャね。\w9めくるミャ。\n\w9\1\i[1]\w9'
	_talk += "\1\i[%(TOINT(_card[0])+2000)]\![anim,offset,%(TOINT(_card[0])+2000),%(200+500),%(13+500)]"
	_talk += "\0…\w5…\w5%(_card[1])の%(_card[2])、\w5%(_正逆)位置ミャね。\w9\w9\w9\w9"
	_talk += '\n[150]'
	_talk += _comment[0] + '\w9\w9\w9\w9\n[150]'
	_talk += _comment[1] + '\w9\w9\w9\w9\n[150]'
	_talk += 'この結果を、\w5（ユーザ）はどう感じたミャ？\_q\n[150]'
	_talk += '\![*]\__q[OnFortune_One_4,希望,希望を感じた]希望を感じた\__q\n'
	_talk += '\![*]\__q[OnFortune_One_4,不安,不安を感じた]不安を感じた\__q\n'
	_talk += '\![*]\__q[OnFortune_One_4,複雑,複雑な気持ち]複雑な気持ち\__q\n'
	_talk += '\![*]\__q[OnFortune_One_4,無感,何も感じない]何も感じない\__q'

	_talk
}

OnFortune_One_4
{
	_card = Fortune_DrawnCards[0] - 1
	_card = Fortune_DeckCards[_card]
	_card[3] = ''

	if TOINT(_card[0]) > 100 {
		_card[3] = '逆'
	}

	// 履歴用にカードと感情を一時保存
	Fortune_CurrentCards ,= _card[0] + ',' + _card[1] + ',' + _card[2]
	Fortune_CurrentEmotions ,= reference[0]

	_comment = EVAL('占い追加語り'+_card[2]+_card[3]+reference[0])

	// 履歴比較
	_prevEmotion = FindMatchingHistory(Fortune_CurrentSubject, Fortune_CurrentCards[0], -1)
	_compTalk = BuildComparisonTalk(_prevEmotion, reference[0])

	_talk = '\![set,balloontimeout,0]\*\0\c\_q'
	_talk += '> ' + reference[1] + '\n[150]\w9\_q'
	if _compTalk != '' {
		_talk += _compTalk + '\w9\w9\w9\w9\n[150]'
	}
	_talk += _comment + "\x\![anim,clear,%(TOINT(_card[0]+2000))]"
	_talk += '\0\c\s[163]\f[italic,1]' + 占いの擬音 + '\f[default]\w9\w9\n[150]' + 占い後コメント + '\x\![raise,OnFortune_SavePrompt]'
	_talk
}

//********************************
// 保存フロー（ワンオラクル・スリーカード共通）
//********************************

OnFortune_SavePrompt
{
	// 占いが終わった後、結果を保存するか尋ねる
	_talk = '\![set,balloontimeout,0]\*\0\s[113]\c'
	_talk += '結果を残しておくミャ？\_q\n\n'
	_talk += '\![*]\q[はい　　　　　　　　,OnFortune_DoSave]\n'
	_talk += '\![*]\q[いいえ　　　　　　　,On占いおしまい]\n'
	_talk
}

OnFortune_DoSave
{
	// 事柄が設定済みならそのまま保存、未設定なら入力を促す
	if Fortune_CurrentSubject != '' {
		SaveFortuneRecord
		_talk = '\![set,balloontimeout,0]\*\0\s[163]\c'
		_talk += '残しておいたミャ。\x\![raise,On占いおしまい]'
		_talk
	}
	else {
		// 事柄名の入力を促す
		_talk = '\![set,balloontimeout,0]\*\0\s[113]\c'
		_talk += '何について占ったか、名前をつけておくミャ？\_q\n\n'
		_talk += BuildSubjectChoices('OnFortune_SaveSubjectSelected', 'OnFortune_SaveSubjectInputBox', 'OnFortune_SaveNoSubject')
		_talk
	}
}

OnFortune_SaveSubjectSelected
{
	// 過去の事柄名を選択した場合
	Fortune_CurrentSubject = reference[0]
	SaveFortuneRecord
	_talk = '\![set,balloontimeout,0]\*\0\s[163]\c'
	_talk += '残しておいたミャ。\x\![raise,On占いおしまい]'
	_talk
}

OnFortune_SaveSubjectInputBox
{
	// 自由入力のinputboxを開く
	'\![open,inputbox,OnFortune_SaveSubjectInputted,-1]'
}

OnFortune_SaveSubjectInputted
{
	// 自由入力の結果を受け取り
	if reference[0] != '' {
		Fortune_CurrentSubject = SHIORI3FW.EscapeAllTags(reference[0])
	}
	SaveFortuneRecord
	_talk = '\![set,balloontimeout,0]\*\0\s[163]\c'
	_talk += '残しておいたミャ。\x\![raise,On占いおしまい]'
	_talk
}

OnFortune_SaveNoSubject
{
	Fortune_CurrentSubject = '(無題)'
	SaveFortuneRecord
	_talk = '\![set,balloontimeout,0]\*\0\s[163]\c'
	_talk += '残しておいたミャ。\x\![raise,On占いおしまい]'
	_talk
}

On占いおしまい
{
	// 読み上げてから占いをおしまいにするためにイベントを分ける

	// カード選択待機状態を解除
	Fortune_DrawWaiting = 0
	// マウスに対する反応＆キー押下に対する反応を止めるフラグ
	割り込み防止フラグ = 0

	// 履歴用一時変数をクリア
	Fortune_CurrentSubject = ''
	Fortune_CurrentCards = IARRAY
	Fortune_CurrentEmotions = IARRAY
	Fortune_CurrentType = ''

	// デッキ等もクリア
	Fortune_DeckCards = IARRAY
	Fortune_DrawnCards = IARRAY
	Fortune_ThreeCards = IARRAY

	'\![leave,nouserbreakmode]\1\s[10]\![raise,On占いトップメニュー]'
}

//********************************
// スリーカード（三枚引き）
//********************************
OnFortune_Three_Start
{
	// マウスに対する反応＆キー押下に対する反応を止めるフラグ
	割り込み防止フラグ = 1

	// 変数を初期化
	Fortune_DrawnCards = IARRAY
	Fortune_DeckCards = IARRAY

	_talk = '\*\1\s[2000]\0\s[113]'
	_talk += '\![enter,nouserbreakmode]\![set,balloontimeout,0]'
	_talk += '机を出したミャ。\w9\n'
	_talk += '見えにくかったら、\w5今のうちに調整するミャ。\n[150]\_q'
	_talk += '\![*]\__q[OnFortune_Three_SubjectInput]進む　　　　　　　　\__q'
	_talk
}

OnFortune_Three_SubjectInput
{
	Fortune_CurrentType = '3'
	Fortune_CurrentSubject = ''
	Fortune_CurrentCards = IARRAY
	Fortune_CurrentEmotions = IARRAY

	_talk = '\![set,balloontimeout,0]\*\0\s[113]\c'
	_talk += '何について占うか、名前をつけておくミャ？\n'
	_talk += '（あとで結果を振り返るときに使うミャ）\_q\n\n'
	_talk += BuildSubjectChoices('OnFortune_Three_SubjectSelected', 'OnFortune_Three_SubjectInputBox', 'OnFortune_Three_SubjectSkip')
	_talk
}

OnFortune_Three_SubjectSelected
{
	Fortune_CurrentSubject = reference[0]
	'\![raise,OnFortune_Three_2]'
}

